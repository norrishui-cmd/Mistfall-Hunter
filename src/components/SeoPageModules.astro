---
import type { SeoPage } from '../data/seoPages';

interface Props {
  page: SeoPage;
  labels?: {
    quick: string;
    checklist: string;
    steps: string;
    tables: string;
  };
}

const { page } = Astro.props as Props;
const labels = Astro.props.labels ?? {
  quick: 'Quick answer',
  checklist: 'Checklist',
  steps: 'Step plan',
  tables: 'Reference table',
};
---

{(page.intent || page.checklist) && (
  <div class={`seo-module seo-module--${page.template ?? 'guide'}`}>
    {page.intent && (
      <div class="intent-grid">
        <div>
          <span class="eyebrow">{labels.quick}</span>
          <h2>{page.intent.primary}</h2>
          <p>{page.intent.freshness}</p>
        </div>
      </div>
    )}

    {page.checklist && (
      <div class="module-block">
        <h2>{labels.checklist}</h2>
        <ul class="check-grid">
          {page.checklist.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    )}
  </div>
)}

{page.steps && (
  <div class="module-block">
    <span class="eyebrow">{labels.steps}</span>
    <div class="step-grid">
      {page.steps.map((step, index) => (
        <article class="step-card">
          <span>{String(index + 1).padStart(2, '0')}</span>
          <h3>{step.title}</h3>
          <p>{step.body}</p>
        </article>
      ))}
    </div>
  </div>
)}

{page.tables && (
  <div class="module-block">
    <span class="eyebrow">{labels.tables}</span>
    {page.tables.map((table) => (
      <div class="table-wrap">
        <h2>{table.title}</h2>
        <table>
          <thead>
            <tr>
              {table.headers.map((header) => <th>{header}</th>)}
            </tr>
          </thead>
          <tbody>
            {table.rows.map((row) => (
              <tr>
                {row.map((cell) => <td>{cell}</td>)}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ))}
  </div>
)}
