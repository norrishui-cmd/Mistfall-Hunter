---
import BaseLayout from '../layouts/BaseLayout.astro';
import { localizedCorePages, localizedCorePath, type LocalizedCorePage } from '../data/localizedCorePages';

interface Props {
  lang: 'de' | 'ja';
  page: LocalizedCorePage;
}

const { lang, page } = Astro.props as Props;
const site = Astro.site ?? new URL('https://mistfallhunter.me');
const path = page.slug === 'home' ? '/' : `/${page.slug}`;
const labels = lang === 'de'
  ? { verified: 'Geprüfte Grundlagen', sources: 'Offizielle Quellen', related: 'Weitere deutsche Guides', open: 'Öffnen', updated: 'Aktualisiert: 18. Juli 2026' }
  : { verified: '確認済みの基本情報', sources: '公式情報源', related: '関連する日本語攻略', open: '開く', updated: '更新日：2026年7月18日' };
const allPages = localizedCorePages[lang];
const related = allPages.filter((item) => item.slug !== page.slug).slice(0, 4);
const sourceUrls = [
  'https://store.steampowered.com/app/3282300/Mistfall_Hunter/',
  'https://www.xbox.com/en-US/games/store/mistfall-hunter/9p8x6tvw9zw8',
];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': page.slug === 'home' ? 'WebPage' : 'Article',
  headline: page.h1,
  description: page.description,
  inLanguage: lang,
  dateModified: '2026-07-18',
  mainEntityOfPage: new URL(localizedCorePath(lang, page.slug), site).href,
  author: { '@type': 'Organization', name: 'Mistfall Hunter Wiki and Hub' },
  publisher: { '@type': 'Organization', name: 'Mistfall Hunter Wiki and Hub' },
  citation: sourceUrls,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: page.slug === 'home' ? [
    { '@type': 'ListItem', position: 1, name: page.h1, item: new URL(localizedCorePath(lang, 'home'), site).href },
  ] : [
    { '@type': 'ListItem', position: 1, name: lang === 'de' ? 'Start' : 'ホーム', item: new URL(localizedCorePath(lang, 'home'), site).href },
    { '@type': 'ListItem', position: 2, name: page.h1, item: new URL(localizedCorePath(lang, page.slug), site).href },
  ],
};
---

<BaseLayout lang={lang} path={path} title={page.title} description={page.description} jsonLd={[articleSchema, breadcrumbSchema]}>
  <section class="section">
    <div class="container">
      <span class="eyebrow">{page.eyebrow}</span>
      <h1 class="page-title">{page.h1}</h1>
      <p class="lead">{page.lead}</p>

      <aside class="quality-panel" aria-label={labels.verified}>
        <span class="eyebrow">{labels.verified}</span>
        <p>{labels.updated}</p>
        <p class="quality-sources">
          <strong>{labels.sources}:</strong>{' '}
          <a href={sourceUrls[0]} rel="noopener noreferrer">Steam</a>{' / '}
          <a href={sourceUrls[1]} rel="noopener noreferrer">Xbox</a>
        </p>
      </aside>

      <div class="prose">
        {page.sections.map((section) => (
          <Fragment>
            <h2>{section.heading}</h2>
            {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            {section.bullets && <ul>{section.bullets.map((item) => <li>{item}</li>)}</ul>}
          </Fragment>
        ))}
      </div>
    </div>
  </section>

  <section class="section related-section">
    <div class="container">
      <h2 class="section-title">{labels.related}</h2>
      <div class="cards related-cards">
        {related.map((item) => (
          <a class="card" href={localizedCorePath(lang, item.slug)}>
            <span class="card-title">{item.h1}</span>
            <span class="card-desc">{item.description}</span>
            <span class="card-arrow">{labels.open} -&gt;</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
