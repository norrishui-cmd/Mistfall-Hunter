---
import { getPriorityLinks, type PriorityLink } from '../data/priorityLinks';
import type { Lang } from '../i18n';

interface Props {
  lang: Lang;
  title?: string;
  eyebrow?: string;
  groups?: PriorityLink['group'][];
  limit?: number;
}

const { lang, groups, limit = 6 } = Astro.props;
const title = Astro.props.title ?? (lang === 'zh' ? '继续探索' : 'Explore next');
const eyebrow = Astro.props.eyebrow ?? (lang === 'zh' ? '站内导航' : 'Internal links');
const links = getPriorityLinks(lang, groups).slice(0, limit);
const readLabel = lang === 'zh' ? '查看' : 'Open';
---

<section class="section related-section">
  <div class="container">
    <span class="eyebrow">{eyebrow}</span>
    <h2 class="section-title">{title}</h2>
    <div class="cards related-cards">
      {links.map((link) => (
        <a class="card" href={link.href}>
          <span class="card-title">{link.title}</span>
          <span class="card-desc">{link.desc}</span>
          <span class="card-arrow">{readLabel} -></span>
        </a>
      ))}
    </div>
  </div>
</section>
