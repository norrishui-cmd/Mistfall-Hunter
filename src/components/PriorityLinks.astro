---
import { getPriorityLinks } from '../data/priorityLinks';
import type { PriorityLink } from '../data/priorityLinks';
import type { Lang } from '../i18n';
import { isIndexableHref } from '../data/seoPages';

interface Props {
  lang: Lang;
  title?: string;
  eyebrow?: string;
  groups?: PriorityLink['group'][];
  limit?: number;
  currentHref?: string;
  seedText?: string;
}

const { lang, groups, limit = 6, currentHref = '', seedText = '' } = Astro.props as Props;
const title = Astro.props.title ?? (lang === 'zh' ? 'Continue exploring' : 'Explore next');
const eyebrow = Astro.props.eyebrow ?? (lang === 'zh' ? 'Internal links' : 'Internal links');
const readLabel = lang === 'zh' ? 'Open' : 'Open';

const seedWords = seedText
  .toLowerCase()
  .replace(/[^a-z0-9\s-]/g, ' ')
  .split(/\s+/)
  .filter((word) => word.length > 3);

const links = getPriorityLinks(lang, groups)
  // A noindex draft should not receive repeated sitewide links from pages we
  // are asking Google to rank. It can stay available via its direct URL.
  .filter((link) => isIndexableHref(link.href))
  .filter((link) => link.href !== currentHref)
  .map((link, index) => {
    const haystack = `${link.title} ${link.desc} ${link.href}`.toLowerCase();
    const keywordScore = seedWords.reduce((score, word) => score + (haystack.includes(word) ? 2 : 0), 0);
    return { link, score: keywordScore - index * 0.001 };
  })
  .sort((a, b) => b.score - a.score)
  .slice(0, limit)
  .map((item) => item.link);
---

{links.length > 0 && (
  <section class="section related-section">
    <div class="container">
      <span class="eyebrow">{eyebrow}</span>
      <h2 class="section-title">{title}</h2>
      <div class="cards related-cards">
        {links.map((link) => (
          <a class="card" href={link.href}>
            <span class="card-title">{link.title}</span>
            <span class="card-desc">{link.desc}</span>
            <span class="card-arrow">{readLabel} -></span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
