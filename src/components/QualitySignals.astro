---
import type { Lang } from '../i18n';
import { getSourceLabels, lastUpdated, sources } from '../data/siteQuality';

interface Props {
  lang: Lang;
  status?: {
    confirmed?: string[];
    preview?: string[];
    verify?: string[];
  };
}

const { lang, status } = Astro.props as Props;
const labels = getSourceLabels(lang);
const sourceHref = lang === 'zh' ? '/zh/sources' : '/sources';

const confirmed = status?.confirmed ?? [
  'Mistfall Hunter is a dark fantasy PvPvE extraction action RPG.',
  'The site separates official information, preview observations, and launch-day verification notes.',
];
const preview = status?.preview ?? [
  'Class, map, extraction, and boss guidance may use preview or demo context before launch.',
  'Exact routes, drops, values, and balance recommendations should be updated with live-game data.',
];
const verify = status?.verify ?? [
  'Final launch patch notes',
  'Live map markers',
  'Exact affix values',
  'Boss drops and spawn rules',
];
---

<aside class="quality-panel" aria-label={labels.quality}>
  <div class="quality-head">
    <span class="eyebrow">{labels.quality}</span>
    <p><strong>{labels.updated}:</strong> {lastUpdated}</p>
    <a href={sourceHref}>{labels.sources} -></a>
  </div>

  <div class="quality-grid">
    <section>
      <h2>{labels.confirmed}</h2>
      <ul>{confirmed.map((item) => <li>{item}</li>)}</ul>
    </section>
    <section>
      <h2>{labels.preview}</h2>
      <ul>{preview.map((item) => <li>{item}</li>)}</ul>
    </section>
    <section>
      <h2>{labels.verify}</h2>
      <ul>{verify.map((item) => <li>{item}</li>)}</ul>
    </section>
  </div>

  <p class="quality-sources">
    {sources.slice(0, 3).map((source) => source.publisher).join(' / ')}
  </p>
</aside>
