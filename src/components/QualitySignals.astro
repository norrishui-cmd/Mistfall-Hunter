---
import type { Lang } from '../i18n';
import type { SeoPage } from '../data/seoPages';
import { getSourceLabels, sources as siteSources } from '../data/siteQuality';

interface Props {
  lang: Lang;
  status?: {
    confirmed?: string[];
    preview?: string[];
    verify?: string[];
  };
  page?: SeoPage;
}

const { lang, status, page } = Astro.props as Props;
const labels = getSourceLabels(lang);
const sourceHref = lang === 'zh' ? '/zh/sources' : '/sources';

const confirmed = page?.evidenceStatus?.confirmed ?? status?.confirmed ?? [];
const preview = page?.evidenceStatus?.betaObserved ?? status?.preview ?? [];
const verify = page?.evidenceStatus?.unverified ?? status?.verify ?? [];
const pageSources = page?.sources ?? [];
const hasEvidence = Boolean(page?.verifiedAt || page?.updatedAt || confirmed.length || preview.length || verify.length || pageSources.length);
---

{hasEvidence && (
  <aside class="quality-panel" aria-label={labels.quality}>
    <div class="quality-head">
      <span class="eyebrow">{labels.quality}</span>
      {page?.verifiedAt && <p><strong>{labels.verified}:</strong> {page.verifiedAt}</p>}
      {page?.updatedAt && <p><strong>{labels.updated}:</strong> {page.updatedAt}</p>}
      <a href={sourceHref}>{labels.sources} -></a>
    </div>

    <div class="quality-grid">
      {confirmed.length > 0 && (
        <section>
          <h2>{labels.confirmed}</h2>
          <ul>{confirmed.map((item) => <li>{item}</li>)}</ul>
        </section>
      )}
      {preview.length > 0 && (
        <section>
          <h2>{labels.preview}</h2>
          <ul>{preview.map((item) => <li>{item}</li>)}</ul>
        </section>
      )}
      {verify.length > 0 && (
        <section>
          <h2>{labels.verify}</h2>
          <ul>{verify.map((item) => <li>{item}</li>)}</ul>
        </section>
      )}
      {pageSources.length > 0 && (
        <section>
          <h2>{labels.sources}</h2>
          <ul>
            {pageSources.map((source) => (
              <li>
                <a href={source.url} target="_blank" rel="noopener noreferrer">{source.title}</a>
                {source.supports?.length ? ` - ${source.supports.join('; ')}` : ''}
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>

    {pageSources.length === 0 && (
      <p class="quality-sources">
        {siteSources.slice(0, 3).map((source) => source.publisher).join(' / ')}
      </p>
    )}
  </aside>
)}
