---
import type { Lang } from '../i18n';
import { getSourceLabels, lastUpdated, sources } from '../data/siteQuality';

interface Props {
  lang: Lang;
  status?: {
    confirmed?: string[];
    preview?: string[];
    verify?: string[];
  };
}

const { lang, status } = Astro.props as Props;
const labels = getSourceLabels(lang);
const sourceHref = lang === 'zh' ? '/zh/sources' : '/sources';

const heading = lang === 'zh' ? '参考与更新说明' : 'Sources and update policy';
const copy = lang === 'zh'
  ? '本页优先引用官方游戏页与商店信息；测试期观察和未确认机制会明确标注，并在官方公告或正式版实测后更新。'
  : 'This page prioritizes official game and storefront information. Preview observations and unconfirmed mechanics are labeled and revised when official updates or live testing provide better evidence.';
---

<aside class="quality-panel" aria-label={heading}>
  <div class="quality-head">
    <span class="eyebrow">{heading}</span>
    <p><strong>{labels.updated}:</strong> <time datetime={lastUpdated}>{lastUpdated}</time></p>
    <a href={sourceHref}>{labels.sources} -></a>
  </div>
  <p>{copy}</p>
  <p class="quality-sources">
    {sources.slice(0, 3).map((source, index) => (
      <Fragment>{index > 0 && ' / '}<a href={source.url} rel="noopener noreferrer" target="_blank">{source.publisher}</a></Fragment>
    ))}
  </p>
</aside>
