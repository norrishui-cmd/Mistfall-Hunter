---
import { sources } from '../data/siteQuality';

interface LinkItem {
  title: string;
  desc: string;
  href: string;
}

interface Props {
  updated?: string;
  confirmed: string[];
  watch: string[];
  links: LinkItem[];
}

const {
  updated = '2026-07-15',
  confirmed,
  watch,
  links,
} = Astro.props as Props;
---

<aside class="quality-panel" aria-label="Editorial quality notes">
  <div class="quality-head">
    <div>
      <span class="eyebrow">Quality notes</span>
      <p>Last checked: {updated}. Confirmed facts are separated from launch-watch items.</p>
    </div>
    <a href="/sources">Sources policy</a>
  </div>
  <p class="quality-sources">
    {sources.slice(0, 3).map((source, index) => (
      <Fragment>{index > 0 && ' / '}<a href={source.url} rel="noopener noreferrer" target="_blank">{source.publisher}</a></Fragment>
    ))}
  </p>
  <div class="quality-grid">
    <section>
      <h2>Confirmed on this page</h2>
      <ul>
        {confirmed.map((item) => <li>{item}</li>)}
      </ul>
    </section>
    <section>
      <h2>Needs launch verification</h2>
      <ul>
        {watch.map((item) => <li>{item}</li>)}
      </ul>
    </section>
    <section>
      <h2>Next best pages</h2>
      <ul>
        {links.map((link) => (
          <li><a href={link.href}>{link.title}</a> - {link.desc}</li>
        ))}
      </ul>
    </section>
  </div>
</aside>
