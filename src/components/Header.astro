---
import { languages, localizePath, useTranslations, type Lang } from '../i18n';

interface Props {
  lang: Lang;
  path: string;
}

type NavItem = {
  labelKey: string;
  path: string;
};

const { lang, path } = Astro.props as Props;
const t = useTranslations(lang);

const items: NavItem[] = [
  { labelKey: 'nav.home', path: '/' },
  { labelKey: 'nav.release', path: '/release-date' },
  { labelKey: 'nav.guides', path: '/guides' },
  { labelKey: 'nav.builds', path: '/builds' },
  { labelKey: 'nav.about', path: '/about' },
];

const localizedCorePaths = new Set(['/', '/release-date', '/beginner-guide', '/classes', '/builds', '/guides', '/performance', '/about']);
const languageOptions: Lang[] = localizedCorePaths.has(path) ? ['en', 'zh', 'de', 'ja'] : ['en', 'zh'];
const siteName = t('site.name');
const siteTagline = t('site.tagline');
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={localizePath('/', lang)}>
      <img src="/favicon.svg" alt="" width="28" height="28" />
      <span>
        <span class="brand-name">{siteName}</span>
        <span class="brand-tag">{siteTagline}</span>
      </span>
    </a>

    <div class="header-right">
      <nav class="nav" aria-label="Primary">
        {items.map((item) => (
          <a
            href={localizePath(item.path, lang)}
            aria-current={item.path === path ? 'page' : undefined}
          >
            {t(item.labelKey)}
          </a>
        ))}
      </nav>

      {languageOptions.filter((option) => option !== lang).map((option) => (
        <a class="lang-switch" href={localizePath(path, option)} hreflang={option === 'zh' ? 'zh-Hans' : option}>
          {languages[option]}
        </a>
      ))}
    </div>
  </div>
</header>
