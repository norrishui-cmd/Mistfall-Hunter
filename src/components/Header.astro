---
import { useTranslations, localizePath, type Lang } from '../i18n';

interface Props {
  lang: Lang;
  path: string; // canonical English path of the current page
}

const { lang, path } = Astro.props;
const t = useTranslations(lang);

const items = [
  { key: 'nav.home', path: '/', live: true },
  { key: 'nav.release', path: '/release-date', live: true },
  { key: 'nav.beginner', path: '/beginner-guide', live: true },
  { key: 'nav.classes', path: '/classes', live: true },
  { key: 'nav.performance', path: '/performance', live: true },
  { key: 'nav.map', path: '/map', live: true },
  { key: 'nav.builds', path: '/builds', live: true },
];

const other: Lang = lang === 'zh' ? 'en' : 'zh';
const otherLabel = other === 'zh' ? '中文' : 'English';
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={localizePath('/', lang)}>
      <img src="/favicon.svg" alt="" width="28" height="28" />
      <span>
        <span class="brand-name">{t('site.name')}</span>
        <span class="brand-tag">{t('site.tagline')}</span>
      </span>
    </a>

    <div class="header-right">
      <nav class="nav" aria-label="Primary">
        {items.map((item) =>
          item.live ? (
            <a
              href={localizePath(item.path, lang)}
              aria-current={item.path === path ? 'page' : undefined}
            >
              {t(item.key)}
            </a>
          ) : (
            <span class="navlink">
              {t(item.key)}
              <span class="mini-soon">{t('nav.soon')}</span>
            </span>
          )
        )}
      </nav>

      <a
        class="lang-switch"
        href={localizePath(path, other)}
        hreflang={other === 'zh' ? 'zh-Hans' : 'en'}
      >
        {otherLabel}
      </a>
    </div>
  </div>
</header>
