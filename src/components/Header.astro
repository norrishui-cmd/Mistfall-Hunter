---
import { localizePath, type Lang } from '../i18n';

interface Props {
  lang: Lang;
  path: string;
}

type NavItem = {
  label: string;
  path: string;
};

const { lang, path } = Astro.props as Props;

const items: NavItem[] = [
  { label: 'Home', path: '/' },
  { label: 'Release', path: '/release-date' },
  { label: 'Steam', path: '/steam-page-guide' },
  { label: 'Gameplay', path: '/gameplay-overview' },
  { label: 'Beginner', path: '/beginner-guide' },
  { label: 'Classes', path: '/classes' },
  { label: 'Map', path: '/map' },
  { label: 'Builds', path: '/builds' },
  { label: 'Status', path: '/server-status' },
];

const other: Lang = lang === 'zh' ? 'en' : 'zh';
const otherLabel = other === 'zh' ? 'Chinese' : 'English';
const siteName = 'Mistfall Hunter Wiki and Hub';
const siteTagline = 'Unofficial guide and database';
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={localizePath('/', lang)}>
      <img src="/favicon.svg" alt="" width="28" height="28" />
      <span>
        <span class="brand-name">{siteName}</span>
        <span class="brand-tag">{siteTagline}</span>
      </span>
    </a>

    <div class="header-right">
      <nav class="nav" aria-label="Primary">
        {items.map((item) => (
          <a
            href={localizePath(item.path, lang)}
            aria-current={item.path === path ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <a
        class="lang-switch"
        href={localizePath(path, other)}
        hreflang={other === 'zh' ? 'zh-Hans' : 'en'}
      >
        {otherLabel}
      </a>
    </div>
  </div>
</header>
