---
import { languages, localizePath, useTranslations, type Lang } from '../i18n';
import { isIndexableHref } from '../data/seoPages';

interface Props {
  lang: Lang;
  path: string;
}

type NavItem = {
  labelKey: string;
  path: string;
};

const { lang, path } = Astro.props as Props;
const t = useTranslations(lang);

const items: NavItem[] = [
  { labelKey: 'nav.home', path: '/' },
  { labelKey: 'nav.release', path: '/release-date' },
  { labelKey: 'nav.guides', path: '/guides' },
  ...(lang === 'en' || lang === 'zh' ? [{ labelKey: 'nav.maps', path: '/map' }] : []),
  ...(lang === 'en' || lang === 'zh' ? [{ labelKey: 'nav.bosses', path: '/bosses' }] : []),
  { labelKey: 'nav.builds', path: '/builds' },
  { labelKey: 'nav.data', path: '/game-data' },
  ...(lang === 'en' || lang === 'zh' ? [{ labelKey: 'nav.faq', path: '/faq' }] : []),
  { labelKey: 'nav.about', path: '/about' },
];

const localizedCorePaths = new Set(['/', '/release-date', '/beginner-guide', '/classes', '/builds', '/guides', '/performance', '/about', '/game-data']);
const isGameDataDetail = /^\/game-data\/[^/]+$/.test(path);
const languageOptions: Lang[] = localizedCorePaths.has(path) || isGameDataDetail ? ['en', 'zh', 'de', 'ja'] : ['en', 'zh'];
const languageLabel = lang === 'zh' ? '选择语言' : lang === 'de' ? 'Sprache wählen' : lang === 'ja' ? '言語を選択' : 'Choose language';
const siteName = t('site.name');
const siteTagline = t('site.tagline');
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={localizePath('/', lang)}>
      <img src="/favicon.svg" alt="" width="28" height="28" />
      <span>
        <span class="brand-name">{siteName}</span>
        <span class="brand-tag">{siteTagline}</span>
      </span>
    </a>

    <div class="header-right">
      <nav class="nav" aria-label="Primary">
        {items.map((item) => (
          <a
            href={localizePath(item.path, lang)}
            aria-current={item.path === path ? 'page' : undefined}
          >
            {t(item.labelKey)}
          </a>
        ))}
      </nav>

      <div class="language-select">
        <label for="lang-switch" class="sr-only">{languageLabel}</label>
        <select
          id="lang-switch"
          aria-label={languageLabel}
          onchange="if(this.value) window.location.href=this.value;"
        >
          {languageOptions.map((option) => {
            const targetHref = localizePath(path, option);
            return (
              <option value={targetHref} selected={option === lang}>
                {languages[option]}
              </option>
            );
          })}
        </select>
        <noscript>
          <nav class="language-tabs" aria-label={languageLabel}>
            {languageOptions.map((option) => {
              const targetHref = localizePath(path, option);
              const targetIsDraft = !isIndexableHref(targetHref);
              return (
                <a
                  class="language-tab"
                  href={targetHref}
                  hreflang={option === 'zh' ? 'zh-Hans' : option}
                  lang={option === 'zh' ? 'zh-Hans' : option}
                  aria-current={option === lang ? 'true' : undefined}
                  rel={targetIsDraft ? 'nofollow' : undefined}
                >
                  {languages[option]}
                </a>
              );
            })}
          </nav>
        </noscript>
      </div>
    </div>
  </div>
</header>
