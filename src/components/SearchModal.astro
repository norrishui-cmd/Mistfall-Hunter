---
// Site-wide search, powered by Pagefind (https://pagefind.app).
//
// Pagefind builds a static search index from the final HTML output — see
// the "build" script in package.json (`astro build && pagefind --site
// dist`). It needs zero backend/database, which matches this project's
// fully static Astro setup.
//
// SCOPE: noindex pages are excluded from the index (see the
// data-pagefind-ignore attribute on <html> in BaseLayout.astro) — search
// results only surface the same content Google is allowed to show, not the
// much larger pre-launch draft/thin-content corpus. Only the <main
// data-pagefind-body> region is indexed, so repeated header/nav/footer
// text doesn't pollute every result.
//
// The pagefind-ui.js/css assets referenced below don't exist until the
// pagefind CLI step runs after `astro build` — they are NOT processed by
// Astro/Vite, just plain static files picked up from /pagefind/ at the end
// of the build. `astro dev` won't have them; search only works against a
// full production build (or `astro preview` after a full build).
import { useTranslations, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props as Props;
const t = useTranslations(lang);
const pagefindLang = { en: 'en', zh: 'zh-hans', de: 'de', ja: 'ja' }[lang];
---

<button type="button" class="search-trigger" data-search-open aria-haspopup="dialog">
  <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><circle cx="10.5" cy="10.5" r="6.5" fill="none" stroke="currentColor" stroke-width="2"/><line x1="15.5" y1="15.5" x2="21" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
  <span>{t('nav.search')}</span>
  <kbd class="search-kbd">/</kbd>
</button>

<dialog class="search-dialog" data-search-dialog aria-label={t('nav.search')}>
  <div class="search-dialog__head">
    <p class="search-dialog__hint">{t('search.hint')}</p>
    <button type="button" class="search-dialog__close" data-search-close aria-label={t('search.close')}>&times;</button>
  </div>
  <div id="search-mount" data-pagefind-ui data-lang={pagefindLang}></div>
</dialog>

<script>
  const openButtons = document.querySelectorAll<HTMLButtonElement>('[data-search-open]');
  const dialog = document.querySelector<HTMLDialogElement>('[data-search-dialog]');
  const closeButton = document.querySelector<HTMLButtonElement>('[data-search-close]');
  const mount = document.querySelector<HTMLElement>('#search-mount');
  let loaded = false;

  function loadScript(src: string): Promise<void> {
    return new Promise((resolve, reject) => {
      const existing = document.querySelector(`script[src="${src}"]`);
      if (existing) {
        resolve();
        return;
      }
      const script = document.createElement('script');
      script.src = src;
      script.onload = () => resolve();
      script.onerror = () => reject(new Error(`Failed to load ${src}`));
      document.head.appendChild(script);
    });
  }

  async function ensurePagefindUI() {
    if (loaded || !mount) return;
    loaded = true;
    const cssHref = '/pagefind/pagefind-ui.css';
    if (!document.querySelector(`link[href="${cssHref}"]`)) {
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = cssHref;
      document.head.appendChild(link);
    }
    try {
      await loadScript('/pagefind/pagefind-ui.js');
      const PagefindUI = (window as any).PagefindUI;
      new PagefindUI({
        element: mount,
        showSubResults: true,
        showImages: false,
        excerptLength: 18,
        resetStyles: false,
      });
      const input = mount.querySelector<HTMLInputElement>('input');
      if (input) input.focus();
    } catch (err) {
      mount.textContent = 'Search is unavailable right now.';
    }
  }

  function openDialog() {
    dialog?.showModal();
    ensurePagefindUI();
  }
  function closeDialog() {
    dialog?.close();
  }

  openButtons.forEach((btn) => btn.addEventListener('click', openDialog));
  closeButton?.addEventListener('click', closeDialog);
  dialog?.addEventListener('click', (event) => {
    if (event.target === dialog) closeDialog();
  });
  document.addEventListener('keydown', (event) => {
    const target = event.target as HTMLElement | null;
    const typing = target && ['INPUT', 'TEXTAREA'].includes(target.tagName);
    if (event.key === '/' && !typing && !dialog?.open) {
      event.preventDefault();
      openDialog();
    }
    if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') {
      event.preventDefault();
      dialog?.open ? closeDialog() : openDialog();
    }
  });
</script>

<style>
  .search-trigger {
    display: flex; align-items: center; gap: 0.4em; font-family: var(--mono); font-size: 0.7rem;
    color: var(--ash); background: rgba(255, 255, 255, 0.02); border: 1px solid var(--line); border-radius: 3px;
    padding: 0.5em 0.7em; cursor: pointer; transition: color 0.14s ease, border-color 0.14s ease;
  }
  .search-trigger:hover, .search-trigger:focus-visible { color: var(--gylden); border-color: var(--gylden); }
  .search-kbd {
    font-family: var(--mono); font-size: 0.62rem; color: var(--faint); border: 1px solid var(--line);
    border-radius: 2px; padding: 0 0.35em; margin-left: 0.15em;
  }
  .search-dialog {
    width: min(640px, 92vw); max-height: 76vh; padding: 0; border: 1px solid var(--line); border-radius: 6px;
    background: var(--stone); color: var(--bone);
  }
  .search-dialog::backdrop { background: rgba(6, 7, 9, 0.72); }
  .search-dialog__head {
    display: flex; align-items: start; justify-content: space-between; gap: 1rem;
    padding: 1rem 1.1rem 0.4rem; border-bottom: 1px solid var(--line);
  }
  .search-dialog__hint { color: var(--ash); font-size: 0.8rem; margin: 0.2rem 0 0.8rem; }
  .search-dialog__close {
    background: none; border: 0; color: var(--ash); font-size: 1.4rem; line-height: 1; cursor: pointer; padding: 0 0.2rem;
  }
  .search-dialog__close:hover { color: var(--gylden); }
  #search-mount { padding: 0.6rem 1.1rem 1.1rem; max-height: 62vh; overflow-y: auto; }

  /* Re-theme Pagefind's default UI to match the site's dark palette instead
     of resetStyles-off defaults. */
  :global(.pagefind-ui__search-input) {
    background: var(--ink); color: var(--bone); border: 1px solid var(--line); font-family: inherit;
  }
  :global(.pagefind-ui__result) { border-bottom: 1px solid var(--line); padding: 0.7em 0; }
  :global(.pagefind-ui__result-link) { color: var(--gylden); }
  :global(.pagefind-ui__result-excerpt) { color: var(--ash); }
  :global(.pagefind-ui__message) { color: var(--ash); font-size: 0.85rem; }
</style>
