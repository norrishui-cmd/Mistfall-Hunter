---
import BaseLayout from '../layouts/BaseLayout.astro'; import { gameDataClusters, type GameDataItem } from '../data/gameData'; import { gameDataLocales } from '../data/gameDataLocales';
interface Props{lang:'en'|'zh'|'de'|'ja';item:GameDataItem} const {lang,item}=Astro.props as Props;const zh=lang==='zh';const c=lang==='en'?item.en:zh?item.zh:gameDataLocales[lang][item.slug];const prefix=lang==='en'?'':`/${lang}`;const url=`https://mistfallhunter.me${prefix}/game-data/${item.slug}/`;const cluster=gameDataClusters[item.cluster];
const labels={en:{home:'Home',data:'Game data',verified:'Last verified',source:'Official announcement source',answer:'Direct answer',facts:'Confirmed data',impact:'What it means for players',watch:'What still needs tracking',quality:'Data quality note',qualityText:'This database separates published facts, playtest observations and future development plans. Unreleased values, coordinates and drop rates are not presented as confirmed.',back:'← Back to this data cluster'},zh:{home:'首页',data:'游戏数据',verified:'最后核实',source:'官方公告来源',answer:'直接答案',facts:'已确认数据',impact:'对玩家有什么影响',watch:'仍需追踪',quality:'数据质量说明',qualityText:'本站把官方已发布事实、测试期观察和未来开发计划分开处理。尚未公开的数值、坐标与掉率不会被写成已确认。',back:'← 返回该数据分类'},de:{home:'Start',data:'Spieldaten',verified:'Zuletzt geprüft',source:'Offizielle Quelle',answer:'Direkte Antwort',facts:'Bestätigte Daten',impact:'Bedeutung für Spieler',watch:'Weiter zu prüfen',quality:'Hinweis zur Datenqualität',qualityText:'Diese Datenbank trennt veröffentlichte Fakten, Testbeobachtungen und künftige Pläne. Unveröffentlichte Werte, Positionen und Drop-Raten werden nicht als bestätigt dargestellt.',back:'← Zurück zur Datenkategorie'},ja:{home:'ホーム',data:'ゲームデータ',verified:'最終確認',source:'公式発表',answer:'結論',facts:'確認済みデータ',impact:'プレイヤーへの影響',watch:'今後の確認項目',quality:'データ品質について',qualityText:'公開済みの事実、テスト時の観察、将来予定を分けて扱います。未公開の数値、座標、ドロップ率を確定情報として掲載しません。',back:'← データ分類へ戻る'}}[lang];
const clusterName=lang==='de'?({characters:'Charaktere & Klassen',items:'Items & Ausrüstung',special:'Besondere Spielsysteme',demo:'Beta & Spieltests'} as const)[item.cluster]:lang==='ja'?({characters:'キャラクター・クラス',items:'アイテム・装備',special:'特殊ゲームシステム',demo:'ベータ・プレイテスト'} as const)[item.cluster]:zh?cluster.zh:cluster.en;
const schema={'@context':'https://schema.org','@type':'Article',headline:c.title,description:c.description,url,inLanguage:lang==='zh'?'zh-Hans':lang,dateModified:item.updated,datePublished:item.updated,author:{'@type':'Organization',name:'Mistfall Hunter Wiki and Hub'},publisher:{'@type':'Organization',name:'Mistfall Hunter Wiki and Hub'},citation:[item.source],mainEntityOfPage:url,isAccessibleForFree:true};
---
<BaseLayout lang={lang} path={`/game-data/${item.slug}`} title={c.title} description={c.description} jsonLd={[schema]}>
  <article class="section"><div class="container detail"><nav class="breadcrumbs"><a href={`${prefix}/`}>{labels.home}</a><span>›</span><a href={`${prefix}/game-data`}>{labels.data}</a><span>›</span><span>{clusterName}</span></nav>
    <span class="eyebrow">{clusterName}</span><h1 class="page-title">{c.title}</h1><p class="lead">{c.description}</p><p class="meta">{labels.verified}: <time datetime={item.updated}>{item.updated}</time> · <a href={item.source} rel="noopener noreferrer">{labels.source}</a></p>
    <div class="answer"><span class="eyebrow">{labels.answer}</span><p>{c.answer}</p></div>
    <div class="prose"><h2>{labels.facts}</h2><ul>{c.facts.map(f=><li>{f}</li>)}</ul><h2>{labels.impact}</h2><ul>{c.implications.map(x=><li>{x}</li>)}</ul><h2>{labels.watch}</h2><p>{c.watch}</p><h2>{labels.quality}</h2><p>{labels.qualityText}</p></div>
    <p class="back"><a href={`${prefix}/game-data#${item.cluster}`}>{labels.back}</a></p>
  </div></article>
</BaseLayout>
<style>.detail{max-width:58rem}.breadcrumbs,.meta{display:flex;flex-wrap:wrap;gap:.55rem;color:var(--ash);margin-bottom:2rem}.meta{font-size:.85rem;margin:1rem 0 2rem}.answer{border-left:4px solid var(--gylden);background:var(--stone);padding:1.2rem 1.4rem;margin:2rem 0}.answer p{font-size:1.15rem;margin:.5rem 0 0}.back{margin-top:3rem}</style>
