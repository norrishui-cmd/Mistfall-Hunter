---
import { localizePath, useTranslations, type Lang } from '../i18n';
import { recoveryFocusLinks } from '../data/seoRecovery';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props as Props;
const t = useTranslations(lang);
const year = new Date().getFullYear();

const trustLinks = [
  { label: t('footer.sources'), href: '/sources' },
  { label: t('footer.updates'), href: '/updates' },
  { label: t('footer.sitemap'), href: '/sitemap' },
];

const coreLinks = recoveryFocusLinks.slice(0, 8);
const supportLinks = [
  { title: 'News', href: '/news' },
  { title: 'Bosses', href: '/bosses' },
  { title: 'Performance', href: '/performance' },
];
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">{t('site.name')}</div>

    <nav class="footer-links" aria-label="Core guide pages">
      {coreLinks.map((link) => (
        <a href={localizePath(link.href, lang)}>{link.title}</a>
      ))}
    </nav>

    <nav class="footer-links" aria-label="Support pages">
      {supportLinks.map((link) => (
        <a href={localizePath(link.href, lang)}>{link.title}</a>
      ))}
    </nav>

    <nav class="footer-links" aria-label="Trust and sitemap">
      {trustLinks.map((link) => (
        <a href={localizePath(link.href, lang)}>{link.label}</a>
      ))}
    </nav>

    <p class="footer-disclaimer">{t('footer.disclaimer')}</p>
    <div class="footer-meta">Copyright {year} {t('site.name')}</div>
  </div>
</footer>
