---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BUILDS, CLASS_LIST, AFFIXES } from '../data/builds';

const lang = 'en' as const;
const site = Astro.site ?? new URL('https://mistfallhunter.me');
const nameById = Object.fromEntries(CLASS_LIST.map((c) => [c.id, c.name]));

const faqs = [
  {
    q: 'Are these the best Mistfall Hunter builds?',
    a: "They are starting directions grounded in each class's mechanics. The game launches July 30, 2026 and the meta is not settled, so treat them as where to begin rather than the final word.",
  },
  {
    q: 'What is the best build for beginners?',
    a: "The Mercenary's Block & Punish — armor, blocking, and parries make your early mistakes survivable while you learn.",
  },
  {
    q: 'When will finalized builds be added?',
    a: 'As the community tests the live game after launch. This page expands with verified skills, talents, runes, and exact affixes as the meta forms.',
  },
];

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', site).href },
    { '@type': 'ListItem', position: 2, name: 'Builds', item: new URL('/builds', site).href },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  lang={lang}
  path="/builds"
  title="Mistfall Hunter Builds & Affixes: Starter Loadouts by Class"
  description="Mistfall Hunter build directions for every class — Sorcerer, Shadowstrix, Mercenary, Blackarrow, Seer, and Withered Knight — plus the affix system. Filter by class."
  jsonLd={[breadcrumb, faqSchema]}
>
  <section class="section">
    <div class="container">
      <span class="eyebrow">Builds &amp; affixes</span>
      <h1 class="page-title">Mistfall Hunter builds &amp; affixes</h1>
      <p class="lead">
        Starter loadout directions for every class, plus how the affix system fits in. Filter by
        class, find a direction that matches how you want to play, then tune the details.
      </p>

      <div class="callout callout--warn">
        <span class="eyebrow">Pre-launch</span>
        <p>
          The meta isn't settled — the game launches July 30, 2026. These are <strong>starting
          directions</strong> built on each class's known mechanics, not finalized builds with
          confirmed numbers. Verified skills, talents, runes, and exact affixes get added as the
          community tests the live game.
        </p>
      </div>

      <div class="prose">
        <h2>How gearing works</h2>
        <p>
          Your power comes from more than your class. Gear rolls <strong>affixes</strong> that shape
          how you play, you slot <strong>gems</strong> and chase <strong>legendary gear</strong>, and
          you layer <strong>talents</strong> and <strong>runes</strong> on top. A build is really the
          sum of those choices aimed at one goal — burst, survival, control, or support. The
          directions below pick the goal; you fill in the specifics as you unlock options.
        </p>
      </div>

      <h2 class="section-title" style="margin-top:2rem">Build directions</h2>
      <div class="bfilter">
        <button type="button" data-filter="all" class="is-active">All</button>
        {CLASS_LIST.map((c) => (
          <button type="button" data-filter={c.id}>{c.name}</button>
        ))}
      </div>

      <div class="buildgrid">
        {BUILDS.map((b) => (
          <article class="buildcard" data-class={b.cls}>
            <div class="build-head">
              <span class="build-class">{nameById[b.cls]}</span>
              <div class="build-tags">
                {b.tags.map((t) => <span class="tag">{t}</span>)}
              </div>
            </div>
            <h3 class="build-title">{b.title}</h3>
            <p class="build-summary">{b.en.summary}</p>
            <dl class="build-meta">
              <div><dt>Core idea</dt><dd>{b.en.core}</dd></div>
              <div><dt>Lean toward</dt><dd>{b.en.priorities.join(' · ')}</dd></div>
            </dl>
          </article>
        ))}
      </div>

      <h2 class="section-title" style="margin-top:2.5rem">Affixes</h2>
      <div class="prose">
        <p>
          Affixes are the rolled modifiers on your gear — they're what turn a class into a build. You
          chase the ones that push your chosen goal (more burst, more survivability, lower cooldowns)
          and reroll or replace the rest.
        </p>
      </div>
      <div class="callout">
        <span class="eyebrow">Effects confirming at launch</span>
        <p>
          These affix names showed up in the beta. We're listing what we're tracking; exact effects
          and values get filled in once they're confirmed in the live game.
        </p>
      </div>
      <div class="affixlist">
        {AFFIXES.map((a) => <span class="affix">{a}</span>)}
      </div>

      <div class="prose" style="margin-top:2rem">
        <p>
          Not sure which class fits? Compare them on the <a href="/classes">tier list</a>, learn the
          loop in the <a href="/beginner-guide">beginner guide</a>, or scout zones on the
          <a href="/map"> interactive map</a>.
        </p>
      </div>

      <h2 class="section-title" style="margin-top:2.5rem">FAQ</h2>
      <div class="faq">
        {faqs.map((f) => (
          <div class="faq-item">
            <p class="faq-q">{f.q}</p>
            <p class="faq-a">{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .bfilter { display: flex; gap: 0.4rem; flex-wrap: wrap; margin: 1.3rem 0 1.4rem; }
  .bfilter button {
    font-family: var(--mono); font-size: 0.76rem; letter-spacing: 0.03em;
    padding: 0.5em 0.9em; background: var(--stone); color: var(--ash);
    border: 1px solid var(--line); border-radius: 2px; cursor: pointer;
  }
  .bfilter button:hover { color: var(--gylden); }
  .bfilter button.is-active { color: #0e1014; background: var(--gylden); border-color: var(--gylden); }

  .buildgrid {
    display: grid; gap: 1px; grid-template-columns: repeat(auto-fit, minmax(19rem, 1fr));
    background: var(--line); border: 1px solid var(--line);
  }
  .buildcard { background: var(--abyss); padding: 1.4rem 1.4rem 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .buildcard[hidden] { display: none; }
  .build-head { display: flex; align-items: center; justify-content: space-between; gap: 0.6rem; flex-wrap: wrap; }
  .build-class { font-family: var(--mono); font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gylden); }
  .build-tags { display: flex; gap: 0.3rem; flex-wrap: wrap; }
  .tag {
    font-family: var(--mono); font-size: 0.58rem; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--ash); border: 1px solid var(--line); padding: 0.12em 0.45em; border-radius: 2px;
  }
  .build-title { font-family: var(--display); font-size: 1.5rem; font-weight: 600; color: var(--bone); margin: 0; line-height: 1.1; }
  .build-summary { color: var(--bone); margin: 0; line-height: 1.6; }
  .build-meta { margin: 0.4rem 0 0; display: flex; flex-direction: column; gap: 0.7rem; }
  .build-meta > div { display: flex; flex-direction: column; gap: 0.2rem; }
  .build-meta dt { font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ash); }
  .build-meta dd { margin: 0; color: var(--bone); font-size: 0.92rem; line-height: 1.5; }

  .affixlist { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem; }
  .affix {
    font-family: var(--mono); font-size: 0.8rem; color: var(--bone);
    border: 1px solid var(--line); background: var(--stone);
    padding: 0.4em 0.8em; border-radius: 2px;
  }
</style>

<script>
  import '../scripts/builds.ts';
</script>
