---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CoreQualityPanel from '../../components/CoreQualityPanel.astro';
import TabNewsModule from '../../components/TabNewsModule.astro';
import RelatedFaqModule from '../../components/RelatedFaqModule.astro';

const lang = 'zh' as const;
const site = Astro.site ?? new URL('https://mistfallhunter.me');

const faqs = [
  {
    q: 'Mistfall Hunter 什么时候发售？',
    a: '7 月 17 日官方公告确认于 2026 年 7 月 30 日 01:00（UTC-7）上线；部分地区商店会因时区显示 7 月 29 日。',
  },
  {
    q: 'Mistfall Hunter 有哪些平台？',
    a: '官方开发者公告确认 PC、Xbox Series X|S 与 PS5 同步首发。',
  },
  {
    q: 'Mistfall Hunter 进 Game Pass 吗？',
    a: '会——首发当天即可通过 Xbox Game Pass 在 Xbox 与 PC 上游玩。',
  },
  {
    q: 'Mistfall Hunter 多少钱？',
    a: '7 月 17 日公告确认标准版 24.99 美元、豪华版 39.99 美元，升级包 15 美元，首发约 14 天九折。',
  },
  {
    q: 'Mistfall Hunter 登陆 PS5 吗？',
    a: '登陆。Bellring Games 已正式宣布 PS5 与 PC、Xbox 同步首发。',
  },
  {
    q: '测试进度会保留到正式版吗？',
    a: '不会。公开测试是数据清档测试，参与者只保留外观奖励。',
  },
];

const videoGameSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  name: 'Mistfall Hunter',
  description: 'Bellring Games 开发的暗黑奇幻第三人称 PvPvE 撤离类动作 RPG。',
  genre: ['Action RPG', 'Extraction', 'Dark Fantasy', 'PvPvE'],
  gamePlatform: ['PC', 'Steam', 'Xbox Series X|S', 'PlayStation 5'],
  publisher: { '@type': 'Organization', name: 'Skystone Games' },
  applicationCategory: 'Game',
  operatingSystem: 'Windows, Xbox Series X|S, PlayStation 5',
  datePublished: '2026-07-30',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: 'zh-Hans',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: new URL('/zh/', site).href },
    { '@type': 'ListItem', position: 2, name: '发售日期', item: new URL('/zh/release-date', site).href },
  ],
};
---

<BaseLayout
  lang={lang}
  path="/release-date"
  title="Mistfall Hunter 发售日期、平台与价格（2026）"
  description="Mistfall Hunter 于 2026 年 7 月 30 日 01:00（UTC-7）发售，标准版 24.99 美元、豪华版 39.99 美元，确认登陆 PC、Xbox 与 PS5。"
  jsonLd={[videoGameSchema, faqSchema, breadcrumbSchema]}
>
  <section class="section">
    <div class="container">
      <span class="eyebrow">发售日期</span>
      <h1 class="page-title">Mistfall Hunter 发售日期、平台与价格</h1>
      <p class="lead">
        7 月 17 日官方公告确认 Mistfall Hunter 于 <strong>2026 年 7 月 30 日 01:00（UTC-7）</strong> 发售，登陆 PC、Xbox Series X|S 与 PS5。标准版 24.99 美元，豪华版 39.99 美元。
      </p>

      <CoreQualityPanel
        confirmed={[
          '官方首发时间为 2026 年 7 月 30 日 01:00（UTC-7）。',
          'PC、Xbox Series X|S 与 PS5 同步首发。',
          '标准版 24.99 美元、豪华版 39.99 美元，首发约 14 天九折。',
        ]}
        watch={[
          '各地区商店价格与当地日期显示。',
          '各平台的预载与下载容量。',
          '开服时刻与首日补丁说明。',
        ]}
        links={[
          { title: '更新与补丁追踪', desc: '发售周补丁与平衡性追踪', href: '/zh/updates' },
          { title: '新闻中心', desc: '发售、beta 与官方公告追踪', href: '/zh/news' },
          { title: '服务器状态', desc: '发售日可用性查询', href: '/zh/server-status' },
        ]}
      />

      <hr class="thread" />

      <div class="prose">
        <h2>Mistfall Hunter 什么时候发售？</h2>
        <p>
          7 月 17 日官方首发公告确认 <strong>2026 年 7 月 30 日 01:00（UTC-7）</strong> 上线。
          部分地区商店可能因时区显示 7 月 29 日，应同时参考官方时间戳与本地商店倒计时。
        </p>

        <h2>有哪些平台？</h2>
        <p>Mistfall Hunter 将同时登陆 PC 与当世代主机：</p>
        <ul>
          <li>PC（Steam）</li>
          <li>PC（Xbox 应用 / Microsoft Store）</li>
          <li>Xbox Series X|S</li>
          <li>PlayStation 5</li>
        </ul>
        <p>
          在 Xbox 与 PC 上，首发当天即可通过 <strong>Xbox Game Pass</strong> 游玩。注意：主机端进行
          PvPvE 对战需要在线多人订阅（Game Pass Core 或 Ultimate；需另购）。
        </p>

        <h2>Mistfall Hunter 多少钱？</h2>
        <p><strong>标准版 24.99 美元</strong>，<strong>豪华版 39.99 美元</strong>，豪华升级包 15 美元。官方公告还确认首发约 14 天九折；各地区定价与税费可能不同。</p>

        <h2>有过测试吗？进度会保留吗？</h2>
        <p>
          有——首次公开测试在 Steam Next Fest 期间于 Steam 与 Xbox 同步进行，已于
          <strong>2026 年 6 月 22 日</strong> 结束。这是一次数据清档测试，因此测试进度不会带入正式版。
          参与的玩家会获得专属外观奖励（如测试头像框与表情动作），在用同一账号登录正式版时解锁。
        </p>
        <p>
          这次测试也收到不少关于卡顿与崩溃的反馈，即便是高配机器也会出现，Bellring 表示稳定性是发售前的首要修复目标。
          如果你遇到性能问题，那多半是当前版本的已知问题，而不是你的设备。
        </p>

        <h2>如何为发售做准备</h2>
        <ul>
          <li>在 Steam 加入愿望单，或在 Xbox 与 PlayStation 商店关注，以便发售时收到通知。</li>
          <li>如果你有 Game Pass，它会在首发当天出现在库里。</li>
          <li>在所在地区商店核对当地价格与首发倒计时。</li>
        </ul>
      </div>

      <h2 class="section-title" style="margin-top:2.5rem">常见问题</h2>
      <div class="faq">
        {faqs.map((f) => (
          <div class="faq-item">
            <p class="faq-q">{f.q}</p>
            <p class="faq-a">{f.a}</p>
          </div>
        ))}
      </div>
      <TabNewsModule cluster="release" lang={lang} />
      <RelatedFaqModule cluster="release" lang={lang} />
    </div>
  </section>
</BaseLayout>
