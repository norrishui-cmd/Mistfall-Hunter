---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CoreQualityPanel from '../../components/CoreQualityPanel.astro';

const lang = 'zh' as const;
const site = Astro.site ?? new URL('https://mistfallhunter.me');

const faqs = [
  {
    q: 'Mistfall Hunter 什么时候发售？',
    a: '官方 Steam 与 Xbox 商店目前显示为 2026 年 7 月 29 日；具体解锁时刻请以当地商店为准。',
  },
  {
    q: 'Mistfall Hunter 有哪些平台？',
    a: '官方商店目前确认 PC 与 Xbox Series X|S；PlayStation 的地区上架与时间请以 PlayStation Store 或发行商公告为准。',
  },
  {
    q: 'Mistfall Hunter 进 Game Pass 吗？',
    a: '会——首发当天即可通过 Xbox Game Pass 在 Xbox 与 PC 上游玩。',
  },
  {
    q: 'Mistfall Hunter 是免费游戏吗？',
    a: '尚未官方确认。Xbox 商店曾将其标注为 Free to Play，但 Bellring Games 还没有锁定最终定价。',
  },
  {
    q: 'Mistfall Hunter 登陆 PS5 吗？',
    a: '在能引用 PlayStation Store 页面或发行商公告前，本站不会把 PS5 版本视为已确认信息。',
  },
  {
    q: '测试进度会保留到正式版吗？',
    a: '不会。公开测试是数据清档测试，参与者只保留外观奖励。',
  },
];

const videoGameSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  name: 'Mistfall Hunter',
  description: 'Bellring Games 开发的暗黑奇幻第三人称 PvPvE 撤离类动作 RPG。',
  genre: ['Action RPG', 'Extraction', 'Dark Fantasy', 'PvPvE'],
  gamePlatform: ['PC', 'Steam', 'Xbox Series X|S'],
  publisher: { '@type': 'Organization', name: 'Bellring Games' },
  applicationCategory: 'Game',
  operatingSystem: 'Windows, Xbox Series X|S',
  datePublished: '2026-07-29',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: 'zh-Hans',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: new URL('/zh/', site).href },
    { '@type': 'ListItem', position: 2, name: '发售日期', item: new URL('/zh/release-date', site).href },
  ],
};
---

<BaseLayout
  lang={lang}
  path="/release-date"
  title="Mistfall Hunter 发售日期、平台与价格（2026）"
  description="Mistfall Hunter 的官方 Steam 与 Xbox 商店目前显示 2026 年 7 月 29 日发售，Xbox 与 PC 首发进 Game Pass。已确认平台、测试详情与定价状态一文说清。"
  jsonLd={[videoGameSchema, faqSchema, breadcrumbSchema]}
>
  <section class="section">
    <div class="container">
      <span class="eyebrow">发售日期</span>
      <h1 class="page-title">Mistfall Hunter 发售日期、平台与价格</h1>
      <p class="lead">
        官方 Steam 与 Xbox 商店目前显示 Mistfall Hunter 将于 <strong>2026 年 7 月 29 日</strong> 发售，PC 与
        Xbox 首发当天即进 Xbox Game Pass。不同地区的解锁时刻与最终定价仍可能变化，下面区分已确认和未确认信息。
      </p>

      <CoreQualityPanel
        confirmed={[
          '官方 Steam 与 Xbox 商店目前显示 2026 年 7 月 29 日发售。',
          '官方商店页面确认 PC 与 Xbox Series X|S。',
          '平台、测试与定价信息按已确认和待确认状态分别呈现。',
        ]}
        watch={[
          '最终价格或免费游玩标签。',
          '各平台的预载与下载容量。',
          '开服时刻与首日补丁说明。',
        ]}
        links={[
          { title: 'Steam 在线人数', desc: '趋势与玩家数量查询', href: '/zh/steam-charts-player-count' },
          { title: '价格状态', desc: '价格、版本与 Game Pass', href: '/zh/price-status' },
          { title: '服务器状态', desc: '发售日可用性查询', href: '/zh/server-status' },
        ]}
      />

      <hr class="thread" />

      <div class="prose">
        <h2>Mistfall Hunter 什么时候发售？</h2>
        <p>
          官方 Steam 与 Xbox 商店目前显示 <strong>2026 年 7 月 29 日</strong>。两者尚未提供统一的全球解锁时间表，
          请以所在地区商店显示为准，而不要依赖第三方时区换算。该日期紧随在 Steam Next Fest 期间举行、已于
          2026 年 6 月 22 日结束的公开测试之后。
        </p>

        <h2>有哪些平台？</h2>
        <p>Mistfall Hunter 将同时登陆 PC 与当世代主机：</p>
        <ul>
          <li>PC（Steam）</li>
          <li>PC（Xbox 应用 / Microsoft Store）</li>
          <li>Xbox Series X|S</li>
        </ul>
        <p>
          在 Xbox 与 PC 上，首发当天即可通过 <strong>Xbox Game Pass</strong> 游玩。注意：主机端进行
          PvPvE 对战需要在线多人订阅（Game Pass Core 或 Ultimate；需另购）。
        </p>

        <h2>Mistfall Hunter 是免费游戏吗？</h2>
        <div class="callout callout--warn">
          <span class="eyebrow">尚未确认</span>
          <p>
            Bellring 还没有锁定最终定价。Xbox 商店曾将其标注为 Free to Play，这倾向于免费发售——
            但在官方价格公布之前，请视为未确认。
          </p>
        </div>
        <p>
          不应根据品类惯例推断最终价格模式；只有发行商或官方商店给出明确定价或免费标签后，本站才会更新结论。
        </p>

        <h2>有过测试吗？进度会保留吗？</h2>
        <p>
          有——首次公开测试在 Steam Next Fest 期间于 Steam 与 Xbox 同步进行，已于
          <strong>2026 年 6 月 22 日</strong> 结束。这是一次数据清档测试，因此测试进度不会带入正式版。
          参与的玩家会获得专属外观奖励（如测试头像框与表情动作），在用同一账号登录正式版时解锁。
        </p>
        <p>
          这次测试也收到不少关于卡顿与崩溃的反馈，即便是高配机器也会出现，Bellring 表示稳定性是发售前的首要修复目标。
          如果你遇到性能问题，那多半是当前版本的已知问题，而不是你的设备。
        </p>

        <h2>如何为发售做准备</h2>
        <ul>
          <li>在 Steam 加入愿望单，或在 Xbox 与 PlayStation 商店关注，以便发售时收到通知。</li>
          <li>如果你有 Game Pass，它会在首发当天出现在库里。</li>
          <li>关注官方 Discord 与各渠道，等待定价公布。</li>
        </ul>
      </div>

      <h2 class="section-title" style="margin-top:2.5rem">常见问题</h2>
      <div class="faq">
        {faqs.map((f) => (
          <div class="faq-item">
            <p class="faq-q">{f.q}</p>
            <p class="faq-a">{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
