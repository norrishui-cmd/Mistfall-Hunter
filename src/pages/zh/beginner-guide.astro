---
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'zh' as const;
const site = Astro.site ?? new URL('https://mistfallhunter.me');

const loop = [
  {
    t: '降落进浓雾',
    d: '你会进入一片被浓雾笼罩的区域——比如 Solemn Needles 或 Hallowgrove——单人或最多三人组队。里面的一切都是敌对的。',
  },
  {
    t: '战斗与搜刮',
    d: '击杀 the Corroded，以及守着最好战利品的 Mist Lords，捡装备、收资源。或者走更狠的路线：猎杀其他 Gyldhunter，抢他们身上的东西。',
  },
  {
    t: '找到出口',
    d: '你没法直接走出去。要猎杀一只 Returner Woodling——它会掉落 Soul of Return，也就是开辟归途的钥匙。浓雾里往往不止一个出口。',
  },
  {
    t: '撤离',
    d: '抵达出口，带着背包里的一切离开。这一刻正是其他玩家最想截杀你的时候，所以不到真正离场，这趟都算不上安全。',
  },
  {
    t: '入账，或全部丢光',
    d: '活着撤离，战利品就归你，安全收进 Windrest。而在浓雾里任何时刻倒下，你带进去的、捡到的，全部掉光。',
  },
];

const glossary = [
  { k: 'Weavereach', v: '游戏所在的破碎世界，被诸神遗弃。' },
  { k: 'Gyldenmist', v: '吞噬世界、会腐蚀一切的金色浓雾，也是你的狩猎场。' },
  { k: 'Gyldhunter', v: '你——被复活、深入浓雾收割战利品的猎人。' },
  { k: 'The Corroded', v: '被浓雾扭曲、游荡在各区域的怪物。' },
  { k: 'Mist Lord', v: '守护高价值战利品的强力 Boss。' },
  { k: 'Returner Woodling', v: '你为了拿到出路而猎杀的生物。' },
  { k: 'Soul of Return', v: '由 Returner Woodling 掉落的钥匙道具，用来开辟撤离路径。' },
  { k: 'Windrest', v: '每趟之间回到的安全据点。' },
  { k: 'Gyldenblood', v: '从浓雾中采集的核心资源（也写作 Gyldenblod）。' },
  { k: 'Chaos run', v: '更高风险、更高回报的run类型，掉落更好。' },
];

const faqs = [
  {
    q: '什么是撤离类（extraction）游戏？',
    a: '你进入一片危险区域，一边对抗 AI 怪物和其他玩家一边搜刮，然后争取带着收获离场（撤离）。在撤离成功之前死亡，东西就没了。',
  },
  {
    q: 'Mistfall Hunter 里怎么撤离？',
    a: '猎杀一只 Returner Woodling 拿到 Soul of Return，再抵达地图出口离开。出口通常不止一个。',
  },
  {
    q: '死了会怎样？',
    a: '死亡是绝对的——你带进这趟的东西和搜刮到的东西全部掉落。只有成功撤离带出去的才算保住。',
  },
  {
    q: 'Mistfall Hunter 能单人玩吗？',
    a: '可以。单人，或最多三人组队都行。单人更难，因为没人能救你或替你顶住，但偏潜行的职业让单人非常可行。',
  },
  {
    q: '新手最适合哪个职业？',
    a: 'Mercenary——重甲、格挡和招架让它在你学战斗时最容错。',
  },
];

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: new URL('/zh/', site).href },
    { '@type': 'ListItem', position: 2, name: '新手指南', item: new URL('/zh/beginner-guide', site).href },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: 'zh-Hans',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  lang={lang}
  path="/beginner-guide"
  title="Mistfall Hunter 新手指南：撤离机制怎么运作"
  description="刚上手 Mistfall Hunter？看懂核心撤离循环、如何用 Soul of Return 离场、死亡会损失什么，以及前几趟最实用的新手技巧。"
  jsonLd={[breadcrumb, faqSchema]}
>
  <section class="section">
    <div class="container">
      <span class="eyebrow">新手指南</span>
      <h1 class="page-title">Mistfall Hunter 撤离机制怎么运作</h1>
      <p class="lead">
        Mistfall Hunter 是一款高风险的撤离 RPG：你进入浓雾、为战利品而战，并争取在掉光一切之前离场。
        下面讲清整套循环、死亡的代价，以及怎么熬过你的前几趟。
      </p>

      <hr class="thread" />

      <h2 class="section-title">核心循环</h2>
      <ol class="loop">
        {loop.map((step, i) => (
          <li class="loop-step">
            <span class="loop-num">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h3 class="loop-title">{step.t}</h3>
              <p class="loop-desc">{step.d}</p>
            </div>
          </li>
        ))}
      </ol>

      <div class="prose">
        <h2>为什么死亡这么疼</h2>
        <p>
          整个游戏的张力就在一条规则上：<strong>撤离就保住一切，死亡就一无所有</strong>。
          一趟当中没有任何保底。所以每一场战斗都是一次风险权衡——一次糟糕的接战，
          可能让你一整趟的收获连同走进去时的装备一起清零。高手会把"带着不多的收获安全离场"当成胜利，而不是失败。
        </p>

        <h2>能不能避开 PvP、只单人玩？</h2>
        <p>
          Mistfall Hunter 是 <strong>PvPvE</strong>——敌对猎人始终是威胁的一部分。
          你可以和他们周旋：走得安静些、避开热点区域、挑着打而不是逢人就打。但你没法彻底退出这份危险。
          单人是可行的，尤其在偏潜行的职业上；而最多三人的小队能给你后援，也让硬 Boss 安全得多。
        </p>
      </div>

      <div class="callout">
        <span class="eyebrow">前几趟的技巧</span>
        <ul class="tips">
          <li><strong>先用 Mercenary。</strong>重甲、格挡和招架，让你在早期能扛住自己的失误。</li>
          <li><strong>你不一定要赢——你要的是离场。</strong>脱战是一项技术，活着的run胜过英勇的送命。</li>
          <li><strong>盯住耐力。</strong>耐力系统经过重做，战斗中耗光会要你的命。</li>
          <li><strong>红光攻击要躲不要挡。</strong>那是专门用来破格挡的，翻滚，别一直举盾。</li>
          <li><strong>先打低风险的run。</strong>还在学的时候，别带上你输不起的装备。</li>
          <li><strong>开打前先想好最近的出口</strong>，这样能带着战利品及时撤。</li>
          <li><strong>早点找到 Returner Woodling</strong>，免得局势恶化时还在到处找出路。</li>
        </ul>
      </div>

      <h2 class="section-title" style="margin-top:2.5rem">关键词</h2>
      <dl class="facts">
        {glossary.map((g) => (
          <div class="fact"><dt>{g.k}</dt><dd>{g.v}</dd></div>
        ))}
      </dl>

      <div class="prose">
        <h2>接下来看哪儿</h2>
        <p>
          用<a href="/zh/classes">职业 Tier List</a> 挑个职业；如果游戏卡顿，
          <a href="/zh/performance">性能优化指南</a>能帮你搞定。还在等发售？
          看<a href="/zh/release-date">发售日期、平台与价格</a>。
        </p>
      </div>

      <h2 class="section-title" style="margin-top:2.5rem">常见问题</h2>
      <div class="faq">
        {faqs.map((f) => (
          <div class="faq-item">
            <p class="faq-q">{f.q}</p>
            <p class="faq-a">{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .loop {
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
    border-top: 1px solid var(--line);
  }
  .loop-step {
    display: flex;
    gap: 1.1rem;
    align-items: flex-start;
    padding: 1.3rem 0;
    border-bottom: 1px solid var(--line);
  }
  .loop-num {
    font-family: var(--mono);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--gylden);
    line-height: 1.4;
    flex: 0 0 auto;
    min-width: 2.2rem;
  }
  .loop-title {
    font-family: var(--display);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--bone);
    margin: 0 0 0.3rem;
    line-height: 1.1;
  }
  .loop-desc {
    margin: 0;
    color: var(--ash);
    line-height: 1.6;
  }
  .tips {
    margin: 0;
    padding-left: 1.1rem;
  }
  .tips li {
    margin: 0.5rem 0;
    color: var(--bone);
  }
  .tips li::marker {
    color: var(--gylden);
  }
</style>
