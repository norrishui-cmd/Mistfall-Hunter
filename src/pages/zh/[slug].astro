---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PriorityLinks from '../../components/PriorityLinks.astro';
import FaqBlock from '../../components/FaqBlock.astro';
import SeoPageModules from '../../components/SeoPageModules.astro';
import QualitySignals from '../../components/QualitySignals.astro';
import { getSeoPages, isIndexable } from '../../data/seoPages';
import type { SeoPage } from '../../data/seoPages';
import { lastUpdated } from '../../data/siteQuality';

export function getStaticPaths() {
  return getSeoPages('zh').map((page) => ({ params: { slug: page.slug }, props: { page } }));
}

const lang = 'zh' as const;
const { page } = Astro.props as { page: SeoPage };
const noindex = !isIndexable(page.slug);
const site = Astro.site ?? new URL('https://mistfallhunter.me');
const pageUrl = new URL(`/zh/${page.slug}`, site).href;

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: new URL('/zh/', site).href },
    { '@type': 'ListItem', position: 2, name: page.h1, item: new URL(`/zh/${page.slug}`, site).href },
  ],
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': page.template === 'faq' || page.faqs ? 'Article' : 'TechArticle',
  headline: page.h1,
  description: page.description,
  url: pageUrl,
  inLanguage: 'zh-Hans',
  dateModified: lastUpdated,
  author: { '@type': 'Organization', name: 'Mistfall Hunter Wiki and Hub' },
  publisher: { '@type': 'Organization', name: 'Mistfall Hunter Wiki and Hub' },
  mainEntityOfPage: pageUrl,
  isAccessibleForFree: true,
};

const faqSchema = page.faqs
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: page.faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : undefined;
---

<BaseLayout
  lang={lang}
  path={`/${page.slug}`}
  title={page.title}
  description={page.description}
  jsonLd={faqSchema ? [breadcrumb, articleSchema, faqSchema] : [breadcrumb, articleSchema]}
  noindex={noindex}
>
  <section class="section">
    <div class="container">
      <span class="eyebrow">{page.eyebrow}</span>
      <h1 class="page-title">{page.h1}</h1>
      <p class="lead">{page.lead}</p>

      {page.updated && (
        <div class="callout">
          <span class="eyebrow">状态</span>
          <p>{page.updated}</p>
        </div>
      )}

      {page.facts && (
        <dl class="facts">
          {page.facts.map((fact) => (
            <div class="fact"><dt>{fact.k}</dt><dd>{fact.v}</dd></div>
          ))}
        </dl>
      )}

      {page.cards && (
        <div class="cards" style="margin-top:1.8rem">
          {page.cards.map((card) => {
            const external = card.href.startsWith('http');
            return (
              <a class="card" href={card.href} target={external ? '_blank' : undefined} rel={external ? 'noopener noreferrer' : undefined}>
                <span class="card-title">{card.title}</span>
                <span class="card-desc">{card.desc}</span>
                <span class="card-arrow">{external ? '访问 ->' : '查看 ->'}</span>
              </a>
            );
          })}
        </div>
      )}

      <SeoPageModules
        page={page}
        labels={{
          intent: '搜索意图',
          primary: '核心词',
          secondary: '相关词',
          freshness: '更新策略',
          checklist: '检查清单',
          steps: '执行步骤',
          tables: '资料表',
          related: '相关搜索',
        }}
      />
      <QualitySignals lang={lang} />

      <hr class="thread" />

      <div class="prose">
        {page.sections.map((section) => (
          <Fragment>
            <h2>{section.heading}</h2>
            {section.body.map((paragraph) => <p>{paragraph}</p>)}
            {section.bullets && (
              <ul>
                {section.bullets.map((item) => <li>{item}</li>)}
              </ul>
            )}
          </Fragment>
        ))}
      </div>

      <FaqBlock faqs={page.faqs} title="常见问题" />
    </div>
  </section>

  <PriorityLinks lang={lang} groups={[page.group, 'guides', 'tools']} limit={6} />
</BaseLayout>
