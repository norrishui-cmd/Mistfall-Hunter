---
import BaseLayout from '../../layouts/BaseLayout.astro';
import QualitySignals from '../../components/QualitySignals.astro';
import { getHubLinks } from '../../data/siteQuality';
import { isIndexableHref } from '../../data/seoPages';

const lang = 'zh' as const;
const hubLinks = getHubLinks(lang);
const indexableHubLinks = hubLinks.filter((link) => isIndexableHref(link.href));

const videoGameSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  name: 'Mistfall Hunter',
  description:
    'Mistfall Hunter 是 Bellring Games 开发的暗黑奇幻 PvPvE 撤离动作 RPG。',
  genre: ['动作 RPG', '撤离', '暗黑奇幻', 'PvPvE'],
  gamePlatform: ['PC', 'Steam', 'Xbox Series X|S'],
  publisher: { '@type': 'Organization', name: 'Bellring Games' },
  applicationCategory: 'Game',
  operatingSystem: 'Windows, Xbox Series X|S',
  datePublished: '2026-07-29',
};

const cards = [
  { title: '发售日、平台与价格', desc: '上线时间、平台、Game Pass 与定价状态。', href: '/zh/release-date' },
  { title: '撤离机制', desc: '核心循环、Soul of Return 与死亡惩罚。', href: '/zh/beginner-guide' },
  { title: '职业强度榜', desc: '六大职业的单人、PvP 与新手上手定位。', href: '/zh/classes' },
  { title: '互动地图', desc: '撤离点、Boss、战利品和地标筛选。', href: '/zh/map' },
  { title: '配装与词缀', desc: '职业构筑方向与词缀追踪。', href: '/zh/builds' },
  { title: '性能优化', desc: '卡顿、低帧、崩溃和设置建议。', href: '/zh/performance' },
];
---

<BaseLayout
  lang={lang}
  path="/"
  title="Mistfall Hunter Wiki 攻略站 - 配装、地图与生存指南"
  description="Mistfall Hunter 非官方攻略与数据库：发售日、职业强度榜、配装、互动地图、Boss、FAQ 和新手指南。"
  jsonLd={[videoGameSchema]}
>
  <section class="hero">
    <div class="container">
      <span class="eyebrow">非官方攻略与数据库</span>
      <h1 class="h1">Mistfall<br />Hunter</h1>
      <p class="hero-thesis">进入 Gyldenmist，带着战利品撤离，或者失去一切。</p>
      <p class="hero-sub">
        这里是面向 Mistfall Hunter 的玩家攻略站，整理发售信息、职业、配装、地图、
        Boss、FAQ 与上线后实测计划。
      </p>
      <div class="hero-cta">
        <a class="btn" href="/zh/release-date">发售日与价格</a>
        <a class="btn btn-ghost" href="/zh/sitemap">浏览攻略站</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="eyebrow">开始阅读</span>
      <h2 class="section-title">找到你的下一局路线</h2>
      <div class="cards">
        {cards.map((card) => (
          <a class="card" href={card.href}>
            <span class="card-title">{card.title}</span>
            <span class="card-desc">{card.desc}</span>
            <span class="card-arrow">查看 -></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="eyebrow">站点可信度</span>
      <h2 class="section-title">预览信息与上线后实测分开处理</h2>
      <div class="prose">
        <p>
          Mistfall Hunter 仍处于发售前阶段，因此本站会区分官方确认、媒体试玩观察和
          正式版上线后需要验证的内容。地图点位、Boss 掉落、词缀数值和职业强度会在
          正式版上线后继续更新。
        </p>
      </div>
      <QualitySignals lang={lang} />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="eyebrow">索引中心</span>
      <h2 class="section-title">核心页面入口</h2>
      <div class="cards">
        {indexableHubLinks.map((link) => (
          <a class="card" href={link.href}>
            <span class="card-title">{link.title}</span>
            <span class="card-desc">{link.desc}</span>
            <span class="card-arrow">打开 -></span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
