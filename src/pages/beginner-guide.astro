---
import BaseLayout from '../layouts/BaseLayout.astro';
import CoreQualityPanel from '../components/CoreQualityPanel.astro';

const lang = 'en' as const;
const site = Astro.site ?? new URL('https://mistfallhunter.me');

const loop = [
  {
    t: 'Drop into the mist',
    d: 'You load into a mist-shrouded zone — like Solemn Needles or Hallowgrove — alone or with a squad of up to three. Everything inside is hostile.',
  },
  {
    t: 'Fight and loot',
    d: 'Kill the Corroded and the Mist Lords that guard the best spoils, scavenge gear, and gather resources. Or take the ruthless path and hunt rival Gyldhunters for what they are carrying.',
  },
  {
    t: 'Find your way out',
    d: 'You cannot just walk out. Hunt down a Returner Woodling — it drops the Soul of Return, the key that carves a path home. The mist often hides more than one exit.',
  },
  {
    t: 'Extract',
    d: 'Reach an exit and leave with everything in your bags. This is the moment other players want to catch you, so the run is rarely safe until you are out.',
  },
  {
    t: 'Bank it — or lose it all',
    d: 'Extract alive and the haul is yours, safe back at Windrest. Die at any point in the mist and you drop everything you brought in and everything you found.',
  },
];

const glossary = [
  { k: 'Weavereach', v: 'The shattered world the game is set in, abandoned by its gods.' },
  { k: 'Gyldenmist', v: 'The golden, corrupting fog that consumes the world. Your hunting ground.' },
  { k: 'Gyldhunter', v: 'You — a hunter revived to brave the mist and harvest its spoils.' },
  { k: 'The Corroded', v: 'The mist-twisted monsters that roam each zone.' },
  { k: 'Mist Lord', v: 'A powerful boss guarding high-value loot.' },
  { k: 'Returner Woodling', v: 'The creature you hunt to obtain your way out.' },
  { k: 'Soul of Return', v: 'The key item, dropped by a Returner Woodling, that opens a path to extract.' },
  { k: 'Windrest', v: 'The safe hub you return to between runs.' },
  { k: 'Gyldenblood', v: 'A core resource harvested from the mist (also written Gyldenblod).' },
  { k: 'Chaos run', v: 'A higher-risk, higher-reward run type for tougher rewards.' },
];

const faqs = [
  {
    q: 'What is an extraction game?',
    a: 'You enter a dangerous area, gather loot while fighting AI enemies and other players, and try to leave (extract) with what you found. If you die before extracting, you lose it.',
  },
  {
    q: 'How do you extract in Mistfall Hunter?',
    a: 'Hunt down a Returner Woodling to get the Soul of Return, then reach one of the map exits and leave. There is often more than one way out.',
  },
  {
    q: 'What happens when you die?',
    a: 'Death is absolute — you drop everything you brought into the run and everything you looted. Only what you successfully extract is kept.',
  },
  {
    q: 'Can you play Mistfall Hunter solo?',
    a: 'Yes. You can run solo or in a squad of up to three. Solo is harder because there is no one to revive or cover you, but stealth-leaning classes make it very playable.',
  },
  {
    q: 'What is the best class for beginners?',
    a: 'The Mercenary — heavy armor, blocking, and parries make it the most forgiving while you learn the combat.',
  },
];

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', site).href },
    { '@type': 'ListItem', position: 2, name: 'Beginner guide', item: new URL('/beginner-guide', site).href },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  lang={lang}
  path="/beginner-guide"
  title="Mistfall Hunter Beginner Guide: How Extraction Works"
  description="New to Mistfall Hunter? Learn the core extraction loop, how to leave a match with the Soul of Return, what you lose when you die, and the best first-run tips."
  jsonLd={[breadcrumb, faqSchema]}
>
  <section class="section">
    <div class="container">
      <span class="eyebrow">Beginner guide</span>
      <h1 class="page-title">How extraction works in Mistfall Hunter</h1>
      <p class="lead">
        Mistfall Hunter is a high-stakes extraction RPG: you go into the mist, fight for loot, and
        try to get out before you lose it all. Here is the full loop, what death costs you, and how
        to survive your first runs.
      </p>

      <CoreQualityPanel
        confirmed={[
          'Mistfall Hunter is built around PvPvE extraction and loot loss.',
          'Soul of Return and extraction routing are central beginner topics.',
          'Solo and squad play require different risk habits.',
        ]}
        watch={[
          'Exact launch tuning for death penalty and extraction timing.',
          'Final beginner class balance after launch patch notes.',
          'Map-specific first-run routes once live locations are verified.',
        ]}
        links={[
          { title: 'Release date', desc: 'launch timing and platforms', href: '/release-date' },
          { title: 'Classes', desc: 'choose a forgiving first role', href: '/classes' },
          { title: 'Fastest way to extract', desc: 'leave with loot safely', href: '/mistfall-hunter-fastest-way-to-extract' },
        ]}
      />

      <hr class="thread" />

      <h2 class="section-title">The core loop</h2>
      <ol class="loop">
        {loop.map((step, i) => (
          <li class="loop-step">
            <span class="loop-num">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h3 class="loop-title">{step.t}</h3>
              <p class="loop-desc">{step.d}</p>
            </div>
          </li>
        ))}
      </ol>

      <div class="prose">
        <h2>Why dying hurts so much</h2>
        <p>
          The whole tension of the game lives in one rule: <strong>extract and you keep everything;
          die and you keep nothing</strong>. There is no safety net mid-run. That is why every fight
          is a risk calculation — a single bad engage can wipe out a run's worth of loot, including
          the gear you walked in with. Good players treat leaving with a modest haul as a win, not a
          failure.
        </p>

        <h2>Can I avoid PvP or play solo?</h2>
        <p>
          Mistfall Hunter is <strong>PvPvE</strong> — rival hunters are always part of the threat.
          You can play around them: move quietly, avoid hot zones, and pick your fights instead of
          taking every one. But you can't fully opt out of the danger. Solo play is viable,
          especially on stealth-leaning classes, while a squad of up to three gives you backup and
          makes tougher bosses far safer.
        </p>
      </div>

      <div class="callout">
        <span class="eyebrow">First-run tips</span>
        <ul class="tips">
          <li><strong>Start as Mercenary.</strong> Heavy armor, blocking, and parries let you survive your early mistakes.</li>
          <li><strong>You don't have to win — you have to leave.</strong> Disengaging is a skill. Live runs beat heroic deaths.</li>
          <li><strong>Mind your stamina.</strong> The stamina system was reworked; running dry mid-fight gets you killed.</li>
          <li><strong>Dodge red-highlighted attacks.</strong> Those are designed to break blocking — roll instead of holding shield.</li>
          <li><strong>Do low-stakes runs first.</strong> Don't carry gear you can't afford to lose while you're still learning.</li>
          <li><strong>Know your nearest exit</strong> before you start a fight, so you can bail with your loot.</li>
          <li><strong>Find a Returner Woodling earlyish</strong> so you're not scrambling for a way out when things go bad.</li>
        </ul>
      </div>

      <h2 class="section-title" style="margin-top:2.5rem">Key terms</h2>
      <dl class="facts">
        {glossary.map((g) => (
          <div class="fact"><dt>{g.k}</dt><dd>{g.v}</dd></div>
        ))}
      </dl>

      <div class="prose">
        <h2>Where to go next</h2>
        <p>
          Pick a class with the <a href="/classes">class tier list</a>, and if the game stutters,
          the <a href="/performance">performance fix guide</a> sorts that out. Counting down to launch?
          See the <a href="/release-date">release date, platforms &amp; price</a>.
        </p>
      </div>

      <h2 class="section-title" style="margin-top:2.5rem">FAQ</h2>
      <div class="faq">
        {faqs.map((f) => (
          <div class="faq-item">
            <p class="faq-q">{f.q}</p>
            <p class="faq-a">{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .loop {
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
    border-top: 1px solid var(--line);
  }
  .loop-step {
    display: flex;
    gap: 1.1rem;
    align-items: flex-start;
    padding: 1.3rem 0;
    border-bottom: 1px solid var(--line);
  }
  .loop-num {
    font-family: var(--mono);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--gylden);
    line-height: 1.4;
    flex: 0 0 auto;
    min-width: 2.2rem;
  }
  .loop-title {
    font-family: var(--display);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--bone);
    margin: 0 0 0.3rem;
    line-height: 1.1;
  }
  .loop-desc {
    margin: 0;
    color: var(--ash);
    line-height: 1.6;
  }
  .tips {
    margin: 0;
    padding-left: 1.1rem;
  }
  .tips li {
    margin: 0.5rem 0;
    color: var(--bone);
  }
  .tips li::marker {
    color: var(--gylden);
  }
</style>
