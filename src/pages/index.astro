---
import BaseLayout from '../layouts/BaseLayout.astro';
import QualitySignals from '../components/QualitySignals.astro';
import CoreTopicCluster from '../components/CoreTopicCluster.astro';
import { getHubLinks } from '../data/siteQuality';
import { latestNewsLinks } from '../data/seoSprint';
import { enLaunchAnswerLinks } from '../data/urlLaunchAnswerPages';
import { enLaunchWeekClusterLinks } from '../data/urlLaunchWeekClusters';
import { enLaunchDayIntentLinks } from '../data/urlLaunchDayIntents';
import { enPostLaunchEvergreenLinks } from '../data/urlPostLaunchEvergreen';
import { recoveryFocusLinks } from '../data/seoRecovery';
import { isIndexable } from '../data/seoPages';

const lang = 'en' as const;
const hubLinks = getHubLinks(lang);
const indexableNewsLinks = latestNewsLinks.filter((link) => isIndexable(link.href));
const indexableAnswerLinks = enLaunchAnswerLinks.filter((link) => isIndexable(link.href));
const indexableLaunchWeekLinks = enLaunchWeekClusterLinks.filter((link) => isIndexable(link.href));
const indexableLaunchDayLinks = enLaunchDayIntentLinks.filter((link) => isIndexable(link.href));
const indexableEvergreenLinks = enPostLaunchEvergreenLinks.filter((link) => isIndexable(link.href));
const indexableHubLinks = hubLinks.filter((link) => isIndexable(link.href));
const site = Astro.site ?? new URL('https://mistfallhunter.me');
const priorityItemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Mistfall Hunter priority guide pages',
  itemListElement: recoveryFocusLinks.filter((link) => isIndexable(link.href)).map((link, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: link.title,
    url: new URL(link.href, site).href,
  })),
};

const videoGameSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  name: 'Mistfall Hunter',
  description:
    'A dark fantasy third-person PvPvE extraction action RPG from Bellring Games. Drop into the Gyldenmist, fight monsters and rival players for loot, and extract before you lose everything.',
  genre: ['Action RPG', 'Extraction', 'Dark Fantasy', 'PvPvE'],
  gamePlatform: ['PC', 'Steam', 'Xbox Series X|S', 'PlayStation 5'],
  publisher: { '@type': 'Organization', name: 'Skystone Games' },
  author: { '@type': 'Organization', name: 'Bellring Games' },
  applicationCategory: 'Game',
  operatingSystem: 'Windows, Xbox Series X|S, PlayStation 5',
  datePublished: '2026-07-29',
  offers: [
    { '@type': 'Offer', name: 'Standard Edition', price: '24.99', priceCurrency: 'USD', availabilityStarts: '2026-07-30T01:00:00Z' },
    { '@type': 'Offer', name: 'Deluxe Edition', price: '39.99', priceCurrency: 'USD', availabilityStarts: '2026-07-30T01:00:00Z' },
  ],
};

const cards = [
  {
    title: 'Release date, platforms & price',
    desc: "When it launches, where to play, and whether it's free. Updated as Bellring confirms details.",
    href: '/release-date',
  },
  {
    title: 'How extraction works',
    desc: 'The core loop, the Soul of Return, and why dying costs you everything.',
    href: '/beginner-guide',
  },
  {
    title: 'Class tier list',
    desc: 'All six classes ranked for solo, PvP, and beginner play.',
    href: '/classes',
  },
  {
    title: 'Interactive map',
    desc: 'Extraction points, boss spawns, and high-value loot, layered for every zone in the mist.',
    href: '/map',
  },
  {
    title: 'Builds & affixes',
    desc: 'Starter loadout directions for every class, plus how the affix system fits in.',
    href: '/builds',
  },
  {
    title: 'Fix stuttering & boost FPS',
    desc: 'A clean performance checklist for stutter, low FPS, crashes, and settings.',
    href: '/performance',
  },
];
---

<BaseLayout
  lang={lang}
  path="/"
  title="Mistfall Hunter Wiki and Hub - Builds, Maps & Survival Guides"
  description="Unofficial Mistfall Hunter guide: release date, class tiers, builds, interactive maps, bosses, and FAQ for the dark fantasy PvPvE extraction RPG."
  jsonLd={[videoGameSchema, priorityItemListSchema]}
>
  <section class="hero">
    <div class="container">
      <span class="eyebrow">Unofficial guide &amp; database</span>
      <h1 class="h1">Mistfall<br />Hunter</h1>
      <p class="hero-thesis">
        Descend into the Gyldenmist. Come back with the haul, or lose everything.
      </p>
      <p class="hero-sub">
        A dark fantasy PvPvE extraction RPG from Bellring Games. Six classes, brutal
        melee-and-magic combat, and one rule: die in the mist and you drop it all. This is a
        fan-built hub for builds, maps, bosses, and surviving your next run.
      </p>
      <div class="hero-cta">
        <a class="btn" href="/release-date">Release date &amp; price</a>
        <a class="btn btn-ghost" href="/sitemap">Explore the wiki</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="eyebrow">Start here</span>
      <h2 class="section-title">Find your next run</h2>
      <div class="cards">
        {cards.map((card) => (
          <a class="card" href={card.href}>
            <span class="card-title">{card.title}</span>
            <span class="card-desc">{card.desc}</span>
            <span class="card-arrow">Read -></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="eyebrow">Launch watch</span>
      <h2 class="section-title">Trending pages to check before launch</h2>
      <div class="cards">
        {recoveryFocusLinks.filter((link) => isIndexable(link.href)).map((link) => (
          <a class="card" href={link.href}>
            <span class="card-title">{link.title}</span>
            <span class="card-desc">{link.desc}</span>
            <span class="card-arrow">Open -></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {indexableNewsLinks.length > 0 && <section class="section">
    <div class="container">
      <span class="eyebrow">Latest news briefs</span>
      <h2 class="section-title">Pre-launch topics people are searching now</h2>
      <div class="cards">
        {indexableNewsLinks.slice(0, 6).map((link) => (
          <a class="card" href={link.href}>
            <span class="card-title">{link.title}</span>
            <span class="card-desc">{link.desc}</span>
            <span class="card-arrow">Read -></span>
          </a>
        ))}
      </div>
    </div>
  </section>}

  {indexableAnswerLinks.length > 0 && <section class="section">
    <div class="container">
      <span class="eyebrow">Fast answers</span>
      <h2 class="section-title">Launch questions with dedicated pages</h2>
      <div class="cards">
        {indexableAnswerLinks.slice(0, 6).map((link) => (
          <a class="card" href={link.href}>
            <span class="card-title">{link.title}</span>
            <span class="card-desc">{link.desc}</span>
            <span class="card-arrow">Open -></span>
          </a>
        ))}
      </div>
    </div>
  </section>}

  {indexableLaunchWeekLinks.length > 0 && <section class="section">
    <div class="container">
      <span class="eyebrow">Launch week clusters</span>
      <h2 class="section-title">Platform, class, map, and troubleshooting guides</h2>
      <div class="cards">
        {indexableLaunchWeekLinks.slice(0, 6).map((link) => (
          <a class="card" href={link.href}>
            <span class="card-title">{link.title}</span>
            <span class="card-desc">{link.desc}</span>
            <span class="card-arrow">Open -></span>
          </a>
        ))}
      </div>
    </div>
  </section>}

  {indexableLaunchDayLinks.length > 0 && <section class="section">
    <div class="container">
      <span class="eyebrow">Launch day intent</span>
      <h2 class="section-title">Fast pages for release-day searches</h2>
      <div class="cards">
        {indexableLaunchDayLinks.slice(0, 6).map((link) => (
          <a class="card" href={link.href}>
            <span class="card-title">{link.title}</span>
            <span class="card-desc">{link.desc}</span>
            <span class="card-arrow">Open -></span>
          </a>
        ))}
      </div>
    </div>
  </section>}

  {indexableEvergreenLinks.length > 0 && <section class="section">
    <div class="container">
      <span class="eyebrow">Evergreen wiki</span>
      <h2 class="section-title">Post-launch pages built to stay useful</h2>
      <div class="cards">
        {indexableEvergreenLinks.slice(0, 6).map((link) => (
          <a class="card" href={link.href}>
            <span class="card-title">{link.title}</span>
            <span class="card-desc">{link.desc}</span>
            <span class="card-arrow">Open -></span>
          </a>
        ))}
      </div>
    </div>
  </section>}

  <section class="section" id="about">
    <div class="container">
      <span class="eyebrow">The hunt</span>
      <h2 class="section-title">What is Mistfall Hunter?</h2>
      <div class="prose">
        <p>
          Mistfall Hunter is a third-person extraction action RPG set in <strong>Weavereach</strong>,
          a world the gods abandoned. You play a Gyldhunter, venture into the Gyldenmist, fight
          corrupted enemies and rival hunters, and extract before death wipes the run.
        </p>
        <p>
          Each run is a gamble. You pick a class, enter a mist-choked zone, hunt for loot, and decide
          whether another fight is worth risking the bag. To leave, preview coverage describes a
          Soul of Return style extraction objective tied to a Returner target.
        </p>
      </div>

      <dl class="facts">
        <div class="fact"><dt>Developer</dt><dd>Bellring Games</dd></div>
        <div class="fact"><dt>Genre</dt><dd>Dark fantasy PvPvE extraction ARPG</dd></div>
        <div class="fact"><dt>Officially listed platforms</dt><dd>PC and Xbox Series X|S</dd></div>
        <div class="fact"><dt>Players</dt><dd>Solo or squads</dd></div>
        <div class="fact"><dt>Storefront release date</dt><dd>July 29, 2026</dd></div>
        <div class="fact"><dt>Status</dt><dd>Pre-launch tracker</dd></div>
      </dl>

      <QualitySignals lang={lang} />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="eyebrow">Index hub</span>
      <h2 class="section-title">Core pages for Google and players</h2>
      <div class="cards">
        {indexableHubLinks.map((link) => (
          <a class="card" href={link.href}>
            <span class="card-title">{link.title}</span>
            <span class="card-desc">{link.desc}</span>
            <span class="card-arrow">Open -></span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
