---
import BaseLayout from '../layouts/BaseLayout.astro';
import CoreQualityPanel from '../components/CoreQualityPanel.astro';
import TabNewsModule from '../components/TabNewsModule.astro';
import RelatedFaqModule from '../components/RelatedFaqModule.astro';

const lang = 'en' as const;
const site = Astro.site ?? new URL('https://mistfallhunter.me');

const faqs = [
  {
    q: 'When does Mistfall Hunter come out?',
    a: 'The July 17 official launch announcement sets launch for July 30, 2026 at 01:00 UTC-7. Regional storefronts may display July 29 because of time zones.',
  },
  {
    q: 'What platforms is Mistfall Hunter on?',
    a: 'Official developer announcements confirm PC, Xbox Series X|S and PS5 for the simultaneous launch.',
  },
  {
    q: 'Is Mistfall Hunter on Game Pass?',
    a: 'Yes — it is available day one on Xbox Game Pass for Xbox and PC.',
  },
  {
    q: 'How much does Mistfall Hunter cost?',
    a: 'The July 17 announcement sets the Standard Edition at $24.99 and Deluxe Edition at $39.99, with a $15 upgrade and a 10% launch discount for about 14 days.',
  },
  {
    q: 'Is Mistfall Hunter on PS5?',
    a: 'Yes. Bellring Games officially announced that PS5 launches alongside PC and Xbox.',
  },
  {
    q: 'Does beta progress carry over to the full game?',
    a: 'No. The open beta was a data-wipe test; participants keep only cosmetic launch rewards.',
  },
];

const videoGameSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  name: 'Mistfall Hunter',
  description:
    'A dark fantasy third-person PvPvE extraction action RPG from Bellring Games.',
  genre: ['Action RPG', 'Extraction', 'Dark Fantasy', 'PvPvE'],
  gamePlatform: ['PC', 'Steam', 'Xbox Series X|S', 'PlayStation 5'],
  publisher: { '@type': 'Organization', name: 'Skystone Games' },
  applicationCategory: 'Game',
  operatingSystem: 'Windows, Xbox Series X|S, PlayStation 5',
  datePublished: '2026-07-30',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', site).href },
    { '@type': 'ListItem', position: 2, name: 'Release date', item: new URL('/release-date', site).href },
  ],
};
---

<BaseLayout
  lang={lang}
  path="/release-date"
  title="Mistfall Hunter Release Date, PC & Xbox Platforms (2026)"
  description="Mistfall Hunter launches July 30, 2026 at 01:00 UTC-7. Standard costs $24.99, Deluxe $39.99, with PC, Xbox Series X|S and PS5 confirmed."
  jsonLd={[videoGameSchema, faqSchema, breadcrumbSchema]}
>
  <section class="section">
    <div class="container">
      <span class="eyebrow">Release date</span>
      <h1 class="page-title">Mistfall Hunter release date, platforms &amp; price</h1>
      <p class="lead">
        The official July 17 announcement sets launch for <strong>July 30, 2026 at 01:00 UTC-7</strong> on PC,
        Xbox Series X|S and PS5. Standard Edition is $24.99 and Deluxe is $39.99; regional storefront dates and prices can vary.
      </p>

      <CoreQualityPanel
        confirmed={[
          'Official launch time: July 30, 2026 at 01:00 UTC-7.',
          'PC, Xbox Series X|S and PS5 are confirmed for simultaneous launch.',
          'Standard $24.99; Deluxe $39.99; $15 upgrade; 10% introductory discount.',
        ]}
        watch={[
          'Regional storefront prices and local calendar display.',
          'Preload and download-size details by platform.',
          'Launch server timing and day-one patch notes.',
        ]}
        links={[
          { title: 'Steam charts tracker', desc: 'trend and player-count intent', href: '/steam-charts-player-count' },
          { title: 'Price status', desc: 'price, editions, and Game Pass', href: '/price-status' },
          { title: 'Server status', desc: 'launch-day availability checks', href: '/server-status' },
        ]}
      />

      <hr class="thread" />

      <div class="prose">
        <h2>When does Mistfall Hunter release?</h2>
        <p>
          The official July 17 launch announcement gives <strong>July 30, 2026 at 01:00 UTC-7</strong>.
          Some regional storefronts display July 29 because local calendar dates depend on time zone; use the announcement timestamp and your store countdown together.
        </p>

        <h2>What platforms is it on?</h2>
        <p>Mistfall Hunter launches across PC and current-gen consoles:</p>
        <ul>
          <li>PC via Steam</li>
          <li>PC via the Xbox app / Microsoft Store</li>
          <li>Xbox Series X|S</li>
          <li>PlayStation 5</li>
        </ul>
        <p>
          On Xbox and PC it's available day one through <strong>Xbox Game Pass</strong>. Xbox's official
          store page says console online multiplayer requires Game Pass Core or Ultimate, sold separately.
        </p>

        <h2>How much does Mistfall Hunter cost?</h2>
        <p><strong>Standard Edition costs $24.99</strong> and <strong>Deluxe Edition costs $39.99</strong>. The Deluxe upgrade is $15.00, and the official announcement promises a 10% introductory discount for about 14 days. Regional pricing and taxes may differ.</p>

        <h2>Was there a beta? Does my progress carry over?</h2>
        <p>
          Yes — the first open beta ran on Steam and Xbox during Steam Next Fest and closed on
          <strong>June 22, 2026</strong>. It was a data-wipe test, so none of that progress carries
          into the full game. Players who joined earn exclusive cosmetic rewards (such as a beta
          avatar frame and emote) that unlock at launch when you sign in with the same account.
        </p>
        <p>
          The beta also drew complaints about stuttering and crashes, even on strong hardware, and
          Bellring has said stability is its top fix before launch. If you hit performance issues,
          they're known build problems rather than something on your end.
        </p>

        <h2>How to get ready for launch</h2>
        <ul>
          <li>Wishlist it on Steam, or add it on the Xbox and PlayStation stores, to get a launch notification.</li>
          <li>If you have Game Pass, it'll appear in your library on day one.</li>
          <li>Check your regional storefront for the local price and launch countdown.</li>
        </ul>
      </div>

      <h2 class="section-title" style="margin-top:2.5rem">FAQ</h2>
      <div class="faq">
        {faqs.map((f) => (
          <div class="faq-item">
            <p class="faq-q">{f.q}</p>
            <p class="faq-a">{f.a}</p>
          </div>
        ))}
      </div>
      <TabNewsModule cluster="release" lang={lang} />
      <RelatedFaqModule cluster="release" lang={lang} />
    </div>
  </section>
</BaseLayout>
