---
import BaseLayout from '../layouts/BaseLayout.astro';
import CoreQualityPanel from '../components/CoreQualityPanel.astro';
import TabNewsModule from '../components/TabNewsModule.astro';
import RelatedFaqModule from '../components/RelatedFaqModule.astro';

const lang = 'en' as const;
const site = Astro.site ?? new URL('https://mistfallhunter.me');

const faqs = [
  {
    q: 'When does Mistfall Hunter come out?',
    a: 'Official Steam and Xbox listings show July 29, 2026. Check your storefront for the local unlock time.',
  },
  {
    q: 'What platforms is Mistfall Hunter on?',
    a: 'Official storefronts currently list PC and Xbox Series X|S. Check PlayStation Store directly for any regional PlayStation availability or timing.',
  },
  {
    q: 'Is Mistfall Hunter on Game Pass?',
    a: 'Yes — it is available day one on Xbox Game Pass for Xbox and PC.',
  },
  {
    q: 'Is Mistfall Hunter free-to-play?',
    a: "It isn't officially confirmed. The Xbox store has listed it as Free to Play, but Bellring Games has not locked final pricing yet.",
  },
  {
    q: 'Is Mistfall Hunter on PS5?',
    a: 'This site does not treat PS5 availability as confirmed until a PlayStation Store page or publisher announcement is available to cite.',
  },
  {
    q: 'Does beta progress carry over to the full game?',
    a: 'No. The open beta was a data-wipe test; participants keep only cosmetic launch rewards.',
  },
];

const videoGameSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  name: 'Mistfall Hunter',
  description:
    'A dark fantasy third-person PvPvE extraction action RPG from Bellring Games.',
  genre: ['Action RPG', 'Extraction', 'Dark Fantasy', 'PvPvE'],
  gamePlatform: ['PC', 'Steam', 'Xbox Series X|S'],
  publisher: { '@type': 'Organization', name: 'Bellring Games' },
  applicationCategory: 'Game',
  operatingSystem: 'Windows, Xbox Series X|S',
  datePublished: '2026-07-29',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', site).href },
    { '@type': 'ListItem', position: 2, name: 'Release date', item: new URL('/release-date', site).href },
  ],
};
---

<BaseLayout
  lang={lang}
  path="/release-date"
  title="Mistfall Hunter Release Date, PC & Xbox Platforms (2026)"
  description="Mistfall Hunter is listed for July 29, 2026 on PC and Xbox, including day-one Game Pass on Xbox and PC. Confirmed platforms, beta details, and pricing status."
  jsonLd={[videoGameSchema, faqSchema, breadcrumbSchema]}
>
  <section class="section">
    <div class="container">
      <span class="eyebrow">Release date</span>
      <h1 class="page-title">Mistfall Hunter release date, platforms &amp; price</h1>
      <p class="lead">
        Official Steam and Xbox listings show a <strong>July 29, 2026</strong> release for PC and Xbox,
        with day-one Xbox Game Pass on Xbox and PC. Storefront timing and final pricing can still vary by
        region, so this guide separates confirmed listings from open questions.
      </p>

      <CoreQualityPanel
        confirmed={[
          'Official Steam and Xbox listings show July 29, 2026.',
          'Official storefront listings confirm PC and Xbox Series X|S.',
          'Platform, beta, and pricing notes are separated by confirmation status.',
        ]}
        watch={[
          'Final price or free-to-play wording.',
          'Preload and download-size details by platform.',
          'Launch server timing and day-one patch notes.',
        ]}
        links={[
          { title: 'Steam charts tracker', desc: 'trend and player-count intent', href: '/steam-charts-player-count' },
          { title: 'Price status', desc: 'price, editions, and Game Pass', href: '/price-status' },
          { title: 'Server status', desc: 'launch-day availability checks', href: '/server-status' },
        ]}
      />

      <hr class="thread" />

      <div class="prose">
        <h2>When does Mistfall Hunter release?</h2>
        <p>
          The official Steam and Xbox listings currently show <strong>July 29, 2026</strong>. Neither
          listing provides a universal unlock-time table, so use your local storefront rather than a
          third-party time conversion for the final release hour. The date follows the open beta that ran
          during Steam Next Fest and closed on June 22, 2026.
        </p>

        <h2>What platforms is it on?</h2>
        <p>Mistfall Hunter launches across PC and current-gen consoles:</p>
        <ul>
          <li>PC via Steam</li>
          <li>PC via the Xbox app / Microsoft Store</li>
          <li>Xbox Series X|S</li>
        </ul>
        <p>
          On Xbox and PC it's available day one through <strong>Xbox Game Pass</strong>. Xbox's official
          store page says console online multiplayer requires Game Pass Core or Ultimate, sold separately.
        </p>

        <h2>Is Mistfall Hunter free-to-play?</h2>
        <div class="callout callout--warn">
          <span class="eyebrow">Not confirmed</span>
          <p>
            Bellring hasn't locked final pricing. The Xbox listing has shown it as Free to Play,
            which points toward a free release — but until there's an official price announcement,
            treat it as unconfirmed.
          </p>
        </div>
        <p>
          Do not infer its final price model from category conventions. This page will update only when
          Bellring or a storefront publishes a definitive price or free-to-play label.
        </p>

        <h2>Was there a beta? Does my progress carry over?</h2>
        <p>
          Yes — the first open beta ran on Steam and Xbox during Steam Next Fest and closed on
          <strong>June 22, 2026</strong>. It was a data-wipe test, so none of that progress carries
          into the full game. Players who joined earn exclusive cosmetic rewards (such as a beta
          avatar frame and emote) that unlock at launch when you sign in with the same account.
        </p>
        <p>
          The beta also drew complaints about stuttering and crashes, even on strong hardware, and
          Bellring has said stability is its top fix before launch. If you hit performance issues,
          they're known build problems rather than something on your end.
        </p>

        <h2>How to get ready for launch</h2>
        <ul>
          <li>Wishlist it on Steam, or add it on the Xbox and PlayStation stores, to get a launch notification.</li>
          <li>If you have Game Pass, it'll appear in your library on day one.</li>
          <li>Follow the official Discord and channels for the pricing announcement.</li>
        </ul>
      </div>

      <h2 class="section-title" style="margin-top:2.5rem">FAQ</h2>
      <div class="faq">
        {faqs.map((f) => (
          <div class="faq-item">
            <p class="faq-q">{f.q}</p>
            <p class="faq-a">{f.a}</p>
          </div>
        ))}
      </div>
      <TabNewsModule cluster="release" lang={lang} />
      <RelatedFaqModule cluster="release" lang={lang} />
    </div>
  </section>
</BaseLayout>
