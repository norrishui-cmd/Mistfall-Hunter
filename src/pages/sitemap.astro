---
import BaseLayout from '../layouts/BaseLayout.astro';
import CoreTopicCluster from '../components/CoreTopicCluster.astro';
import { getHubLinks } from '../data/siteQuality';
import { getSeoPages, isIndexable } from '../data/seoPages';
import { launchWatchLinks, latestNewsLinks } from '../data/seoSprint';
import { recoveryFocusLinks } from '../data/seoRecovery';

const lang = 'en' as const;
const hubLinks = getHubLinks(lang);
const dynamicLinks = getSeoPages(lang)
  .filter((page) => isIndexable(page))
  .filter((page) => !hubLinks.some((link) => link.href === `/${page.slug}`))
  .map((page) => ({
    title: page.h1,
    desc: page.description,
    href: `/${page.slug}`,
    cluster: page.group,
  }));

const groups = [
  { key: 'core', title: 'Core pages' },
  { key: 'release', title: 'Release and news' },
  { key: 'guides', title: 'Guides' },
  { key: 'maps', title: 'Maps' },
  { key: 'builds', title: 'Builds' },
  { key: 'bosses', title: 'Bosses' },
  { key: 'tools', title: 'Tools' },
];

const site = 'https://mistfallhunter.me';
const sitemapTitle = 'Mistfall Hunter HTML Sitemap';
const sitemapDescription = 'Human-readable Mistfall Hunter sitemap for core guide pages, maps, builds, bosses, tools, sources, and update pages.';

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: sitemapTitle,
  description: sitemapDescription,
  url: `${site}/sitemap/`,
  inLanguage: 'en',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${site}/` },
    { '@type': 'ListItem', position: 2, name: 'Sitemap', item: `${site}/sitemap/` },
  ],
};
---

<BaseLayout
  lang={lang}
  path="/sitemap"
  title={sitemapTitle}
  description={sitemapDescription}
  jsonLd={[pageSchema, breadcrumbSchema]}
>
  <section class="section">
    <div class="container">
      <span class="eyebrow">Discovery</span>
      <h1 class="page-title">Mistfall Hunter sitemap</h1>
      <p class="lead">
        A crawl-friendly index of the site's most important pages. Submit the XML sitemap in
        Google Search Console, and use this page as the human-readable discovery hub.
      </p>

      <div class="module-block">
        <span class="eyebrow">Launch watch</span>
        <div class="cards">
          {launchWatchLinks.filter((link) => isIndexable(link.href)).map((link) => (
            <a class="card" href={link.href}>
              <span class="card-title">{link.title}</span>
              <span class="card-desc">{link.desc}</span>
              <span class="card-arrow">Open -></span>
            </a>
          ))}
        </div>
      </div>

      <div class="module-block">
        <span class="eyebrow">Latest news briefs</span>
        <div class="cards">
          {latestNewsLinks.filter((link) => isIndexable(link.href)).map((link) => (
            <a class="card" href={link.href}>
              <span class="card-title">{link.title}</span>
              <span class="card-desc">{link.desc}</span>
              <span class="card-arrow">Read -></span>
            </a>
          ))}
        </div>
      </div>

      {groups.map((group) => {
        const links = hubLinks.filter((link) => link.cluster === group.key && isIndexable(link.href));
        return links.length ? (
          <div class="module-block">
            <span class="eyebrow">{group.title}</span>
            <div class="cards">
              {links.map((link) => (
                <a class="card" href={link.href}>
                  <span class="card-title">{link.title}</span>
                  <span class="card-desc">{link.desc}</span>
                  <span class="card-arrow">Open -></span>
                </a>
              ))}
            </div>
          </div>
        ) : null;
      })}

      <div class="module-block">
        <span class="eyebrow">Long-tail pages</span>
        <div class="cards">
          {dynamicLinks.slice(0, 120).map((link) => (
            <a class="card" href={link.href}>
              <span class="card-title">{link.title}</span>
              <span class="card-desc">{link.desc}</span>
              <span class="card-arrow">Open -></span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
