---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { lastUpdated, sources } from '../../data/siteQuality';

const lang = 'ja' as const;
const site = 'https://mistfallhunter.me';
const title = 'Mistfall Hunter 情報源と編集方針';
const description = 'Mistfall Hunter Wiki and Hubの情報源と編集方針。公式情報、ストア情報、試遊報道、発売後の実測検証情報の扱い方を説明します。';

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  url: `${site}/ja/sources/`,
  inLanguage: 'ja',
  dateModified: lastUpdated,
  isPartOf: { '@type': 'WebSite', name: 'Mistfall Hunter Wiki and Hub', url: `${site}/` },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${site}/ja/` },
    { '@type': 'ListItem', position: 2, name: '情報源', item: `${site}/ja/sources/` },
  ],
};
---

<BaseLayout
  lang={lang}
  path="/sources"
  title={title}
  description={description}
  jsonLd={[pageSchema, breadcrumbSchema]}
>
  <section class="section">
    <div class="container">
      <span class="eyebrow">情報源</span>
      <h1 class="page-title">情報源と編集方針</h1>
      <p class="lead">
        当サイトは確認済み情報と、試遊レポートや発売日検証待ちの情報を区別しています。最終更新：{lastUpdated}。
      </p>

      <div class="prose">
        <h2>情報の扱い方</h2>
        <p>
          確認済みの事実は公式ページ、ストア、パブリッシャー・開発者の発表に基づきます。
          試遊観察はハンズオン報道によるもので、発売前後で変わる可能性があります。
          正確な数値、ドロップ率、マップ地点、ビルド評価は、実機データで確認できるまで
          確定情報として扱いません。
        </p>
      </div>

      <div class="cards">
        {sources.map((source) => (
          <a class="card" href={source.url} rel="noopener noreferrer" target="_blank">
            <span class="soon-badge">{source.type}</span>
            <span class="card-title">{source.title}</span>
            <span class="card-desc">{source.publisher}: {source.note}</span>
            <span class="card-arrow">情報源を開く -></span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
