---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { lastUpdated } from '../../data/siteQuality';

const lang = 'ja' as const;
const site = 'https://mistfallhunter.me';
const title = 'Mistfall Hunter 更新履歴と発売検証プラン';
const description = 'Mistfall Hunterの更新履歴と発売検証プラン。マップ、ビルド、ボス、FAQ、情報源、攻略の正確性をカバーします。';

const roadmap = [
  ['現在', '発売前の構成', '発売、プラットフォーム、クラス、ビルド、マップ、ボス、FAQ、ツールページをクロール発見しやすいよう整理。'],
  ['発売週', '実機検証', 'マップ地点、クラス数値、Affix、ボス攻略ルート、ドロップ、パフォーマンス情報を実データで更新。'],
  ['パッチ後', 'ランキング更新', 'バランス調整後にビルド、クラス評価、パフォーマンス推奨、ボス報酬価値を見直し。'],
];

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  url: `${site}/ja/updates/`,
  inLanguage: 'ja',
  dateModified: lastUpdated,
  isPartOf: { '@type': 'WebSite', name: 'Mistfall Hunter Wiki and Hub', url: `${site}/` },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${site}/ja/` },
    { '@type': 'ListItem', position: 2, name: '更新情報', item: `${site}/ja/updates/` },
  ],
};
---

<BaseLayout
  lang={lang}
  path="/updates"
  title={title}
  description={description}
  jsonLd={[pageSchema, breadcrumbSchema]}
>
  <section class="section">
    <div class="container">
      <span class="eyebrow">更新情報</span>
      <h1 class="page-title">更新履歴と発売検証プラン</h1>
      <p class="lead">現在の編集時点：{lastUpdated}。発売後は仮の内容を実機検証済みの情報に置き換えます。</p>

      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>時期</th><th>焦点</th><th>更新内容</th></tr>
          </thead>
          <tbody>
            {roadmap.map((row) => (
              <tr>{row.map((cell) => <td>{cell}</td>)}</tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>
</BaseLayout>
