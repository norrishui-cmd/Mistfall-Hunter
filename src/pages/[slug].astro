---
import BaseLayout from '../layouts/BaseLayout.astro';
import PriorityLinks from '../components/PriorityLinks.astro';
import FaqBlock from '../components/FaqBlock.astro';
import SeoPageModules from '../components/SeoPageModules.astro';
import QualitySignals from '../components/QualitySignals.astro';
import { getSeoPages, isIndexable } from '../data/seoPages';
import type { SeoPage } from '../data/seoPages';

export function getStaticPaths() {
  return getSeoPages('en').map((page) => ({ params: { slug: page.slug }, props: { page } }));
}

const lang = 'en' as const;
const { page } = Astro.props as { page: SeoPage };
const noindex = !isIndexable(page.slug);
const site = Astro.site ?? new URL('https://mistfallhunter.me');
const pageUrl = new URL(`/${page.slug}`, site).href;
const seedText = [
  page.title,
  page.h1,
  page.description,
  page.lead,
  page.sections.map((section) => `${section.heading} ${section.body.join(' ')} ${section.bullets?.join(' ') ?? ''}`).join(' '),
  page.relatedSearches?.join(' ') ?? '',
].join(' ');

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', site).href },
    { '@type': 'ListItem', position: 2, name: page.h1, item: pageUrl },
  ],
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': page.template === 'faq' || page.faqs ? 'Article' : 'TechArticle',
  headline: page.h1,
  description: page.description,
  url: pageUrl,
  inLanguage: 'en',
  dateModified: '2026-07-12',
  datePublished: '2026-07-12',
  author: { '@type': 'Organization', name: 'Mistfall Hunter Wiki and Hub' },
  publisher: { '@type': 'Organization', name: 'Mistfall Hunter Wiki and Hub' },
  mainEntityOfPage: pageUrl,
};

const faqSchema = page.faqs
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: page.faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : undefined;
---

<BaseLayout
  lang={lang}
  path={`/${page.slug}`}
  title={page.title}
  description={page.description}
  noindex={noindex}
  jsonLd={faqSchema ? [breadcrumb, articleSchema, faqSchema] : [breadcrumb, articleSchema]}
>
  <section class="section">
    <div class="container">
      <span class="eyebrow">{page.eyebrow}</span>
      <h1 class="page-title">{page.h1}</h1>
      <p class="lead">{page.lead}</p>

      {page.updated && (
        <div class="callout">
          <span class="eyebrow">Status</span>
          <p>{page.updated}</p>
        </div>
      )}

      {page.facts && (
        <dl class="facts">
          {page.facts.map((fact) => (
            <div class="fact"><dt>{fact.k}</dt><dd>{fact.v}</dd></div>
          ))}
        </dl>
      )}

      {page.cards && (
        <div class="cards" style="margin-top:1.8rem">
          {page.cards.map((card) => {
            const external = card.href.startsWith('http');
            return (
              <a class="card" href={card.href} target={external ? '_blank' : undefined} rel={external ? 'noopener noreferrer' : undefined}>
                <span class="card-title">{card.title}</span>
                <span class="card-desc">{card.desc}</span>
                <span class="card-arrow">{external ? 'Visit ->' : 'Open ->'}</span>
              </a>
            );
          })}
        </div>
      )}

      <SeoPageModules page={page} />
      <QualitySignals lang={lang} />

      <hr class="thread" />

      <div class="prose">
        {page.sections.map((section) => (
          <Fragment>
            <h2>{section.heading}</h2>
            {section.body.map((paragraph) => <p>{paragraph}</p>)}
            {section.bullets && (
              <ul>
                {section.bullets.map((item) => <li>{item}</li>)}
              </ul>
            )}
          </Fragment>
        ))}
      </div>

      <FaqBlock faqs={page.faqs} title="FAQ" />
    </div>
  </section>

  <PriorityLinks
    lang={lang}
    groups={[page.group, 'guides', 'tools']}
    limit={8}
    currentHref={`/${page.slug}`}
    seedText={seedText}
  />
</BaseLayout>
