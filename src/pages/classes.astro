---
import BaseLayout from '../layouts/BaseLayout.astro';

const lang = 'en' as const;
const site = Astro.site ?? new URL('https://mistfallhunter.me');

const tiers = [
  { tier: 'S', cls: 'tier-s', names: 'Sorcerer · Shadowstrix', note: 'Highest damage ceiling and the best solo hunter.' },
  { tier: 'A', cls: 'tier-a', names: 'Blackarrow · Withered Knight', note: 'Top ranged DPS and the strongest melee duelist.' },
  { tier: 'B', cls: 'tier-b', names: 'Mercenary', note: 'The most reliable pick and by far the best for beginners.' },
  { tier: 'C', cls: 'tier-c', names: 'Seer (solo only)', note: 'Weakest alone — but jumps to S-tier in a coordinated trio.' },
];

const classes = [
  {
    name: 'Sorcerer',
    badge: 'S', cls: 'tier-s',
    role: 'Ranged spellcaster · glass cannon',
    body: 'The damage king. The Elemental path stacks fire, thunder, and ice reactions; the Stardust path trades that for instant-cast burst. A short blink keeps you out of melee. You delete packs and win teamfights from range — as long as nobody closes the gap.',
    strengths: 'Highest damage ceiling, fast PvE clear, dominant in teamfights.',
    weaknesses: 'Very low HP — one bad position and you are dead.',
    best: 'Players who can manage spacing and positioning.',
  },
  {
    name: 'Shadowstrix',
    badge: 'S', cls: 'tier-s',
    role: 'Stealth assassin · daggers',
    body: 'The solo king. Slip into stealth, pick your target, burst them down, then vanish and reset. You decide when fights happen, which is everything in an extraction game. Punishing in a straight fight if you whiff the opener, but you rarely have to take one.',
    strengths: 'Best solo class, controls every engagement, top duelist.',
    weaknesses: 'Thin margins in a fair fight; struggles into very tanky targets.',
    best: 'Solo players and anyone who likes hunting other hunters.',
  },
  {
    name: 'Mercenary',
    badge: 'B', cls: 'tier-b',
    role: 'Armored frontline · sword & shield or hammer',
    body: 'The starter class. Heavy armor, blocks, parries, shield bash, and stuns make it the most forgiving way to learn the combat. It does everything competently and nothing exceptionally, so at the top level it gets out-scaled — but for your first dozens of hours it is the safest seat in the house.',
    strengths: 'Tanky, forgiving, dependable. The best beginner pick.',
    weaknesses: 'Jack-of-all-trades — falls off against skilled opponents. Never block the red (unblockable) attacks.',
    best: 'Beginners and players who want to survive their mistakes.',
  },
  {
    name: 'Blackarrow',
    badge: 'A', cls: 'tier-a',
    role: 'Bow marksman · ranged',
    body: 'Ranged pressure done right. The Archer path leans on charged shots and arrow detonations; the Hunter path applies bleed, paralysis, and other debuffs. Excellent boss and PvE damage from safety, and strong solo thanks to constant poke — provided your aim holds up.',
    strengths: 'Big boss/PvE damage, safe ranged poke, strong solo.',
    weaknesses: 'Accuracy-dependent; weaker once enemies close the distance.',
    best: 'Players with good aim who prefer to fight from range.',
  },
  {
    name: 'Seer',
    badge: 'C', cls: 'tier-c',
    role: 'Support · catalyst or mace',
    body: 'The team multiplier. Heals, shields, buffs, and crowd control keep a squad alive through fights they should lose; the Reverent (shield) path is easier to pilot than full healing. In a coordinated three-stack it is genuinely top-tier. Solo, it has almost no kill pressure — this is the one class that lives or dies by your group.',
    strengths: 'Enormous value in a coordinated trio; keeps the team standing.',
    weaknesses: 'Weakest class by far when playing solo.',
    best: 'Premade squads and dedicated support players.',
  },
  {
    name: 'Withered Knight',
    badge: 'A', cls: 'tier-a',
    role: 'Heavy melee duelist · two-handed greatsword · newest class',
    body: 'The newest addition and a pure aggressor. Its signature Wither mechanic stacks a debuff you then detonate for heavy damage and executes, while a grappling hook drags fleeing targets back into range. Combo-heavy and parry-capable, it wants to be in your face at all times.',
    strengths: 'Strong 1v1 dueling and huge burst from Wither detonations.',
    weaknesses: 'Must stay in melee — gets kited by ranged and punished if ambushed mid-combo.',
    best: 'Aggressive players who live for melee duels.',
  },
];

const faqs = [
  { q: 'How many classes are in Mistfall Hunter?', a: 'Six: Sorcerer, Shadowstrix, Mercenary, Blackarrow, Seer, and the Withered Knight.' },
  { q: 'What is the best class for beginners?', a: 'The Mercenary — heavy armor, blocking, and parries make it the most forgiving while you learn.' },
  { q: 'What is the strongest class?', a: 'The Sorcerer currently has the highest damage ceiling and was the dominant class in the beta. Expect balance changes around launch.' },
  { q: 'What is the best solo class?', a: 'Shadowstrix, thanks to stealth and on-demand engages. Blackarrow is the strongest ranged solo option.' },
  { q: 'Is the Seer bad?', a: 'Only solo, where it has little kill pressure. In a coordinated three-player squad it is one of the best classes in the game.' },
];

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', site).href },
    { '@type': 'ListItem', position: 2, name: 'Classes', item: new URL('/classes', site).href },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  lang={lang}
  path="/classes"
  title="Mistfall Hunter Classes & Tier List: All 6 Classes Ranked"
  description="All six Mistfall Hunter classes ranked — Sorcerer, Shadowstrix, Mercenary, Blackarrow, Seer, and Withered Knight — with the best picks for solo, PvP, and beginners."
  jsonLd={[breadcrumb, faqSchema]}
>
  <section class="section">
    <div class="container">
      <span class="eyebrow">Classes &amp; tier list</span>
      <h1 class="page-title">Mistfall Hunter classes &amp; tier list</h1>
      <p class="lead">
        Six classes, very different playstyles. Short version: the <strong>Sorcerer</strong> hits
        hardest, <strong>Shadowstrix</strong> is the best solo, the <strong>Mercenary</strong> is the
        easiest to learn, and the <strong>Seer</strong> only shines in a squad. Here is the full
        ranking and a breakdown of each.
      </p>

      <hr class="thread" />

      <h2 class="section-title">Tier list</h2>
      <div class="tier-table">
        {tiers.map((t) => (
          <div class="tier-row">
            <span class={`tier-badge ${t.cls}`}>{t.tier}</span>
            <div class="tier-info">
              <span class="tier-names">{t.names}</span>
              <span class="tier-note">{t.note}</span>
            </div>
          </div>
        ))}
      </div>

      <div class="callout callout--warn">
        <span class="eyebrow">Read this first</span>
        <p>
          This ranking reflects the beta meta and leans PvP. Tiers shift with context — the Seer is
          C-tier solo but S-tier in a trio — and the Sorcerer's dominance drew heavy balance
          complaints, so expect tuning around the July 30 launch. Pick what's fun; almost everything
          is viable with the right build.
        </p>
      </div>

      {classes.map((c) => (
        <article class="class-block">
          <div class="class-head">
            <h2 class="class-name">{c.name}</h2>
            <span class={`tier-badge ${c.cls}`}>{c.badge}</span>
          </div>
          <p class="class-role">{c.role}</p>
          <p class="class-body">{c.body}</p>
          <dl class="sw">
            <div><dt>Strengths</dt><dd>{c.strengths}</dd></div>
            <div><dt>Weaknesses</dt><dd>{c.weaknesses}</dd></div>
            <div><dt>Best for</dt><dd>{c.best}</dd></div>
          </dl>
        </article>
      ))}

      <div class="prose">
        <h2>Builds come next</h2>
        <p>
          Class is only half the story — affixes like Valor and Stoic, plus talents and runes, decide
          how a class actually plays. A full build library is on the way. New to the game? Start with
          <a href="/beginner-guide"> how extraction works</a>.
        </p>
      </div>

      <h2 class="section-title" style="margin-top:2.5rem">FAQ</h2>
      <div class="faq">
        {faqs.map((f) => (
          <div class="faq-item">
            <p class="faq-q">{f.q}</p>
            <p class="faq-a">{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .tier-table {
    border: 1px solid var(--line);
    margin: 1.5rem 0 0;
  }
  .tier-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.1rem;
    border-bottom: 1px solid var(--line);
  }
  .tier-row:last-child { border-bottom: 0; }
  .tier-info { display: flex; flex-direction: column; gap: 0.15rem; }
  .tier-names { font-family: var(--display); font-size: 1.2rem; font-weight: 600; color: var(--bone); }
  .tier-note { color: var(--ash); font-size: 0.88rem; }

  .tier-badge {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 3px;
    font-family: var(--mono);
    font-weight: 600;
    font-size: 1rem;
    border: 1px solid;
  }
  .tier-s { color: #f2d27a; border-color: #c8a042; background: rgba(200, 160, 66, 0.12); }
  .tier-a { color: #9fd0c9; border-color: #5f8f89; background: rgba(127, 168, 163, 0.12); }
  .tier-b { color: var(--bone); border-color: var(--ash); background: rgba(150, 156, 166, 0.1); }
  .tier-c { color: #d08a82; border-color: #9b4a4a; background: rgba(177, 90, 82, 0.1); }

  .class-block {
    padding: 1.6rem 0;
    border-bottom: 1px solid var(--line);
  }
  .class-block:first-of-type { border-top: 1px solid var(--line); }
  .class-head { display: flex; align-items: center; gap: 0.8rem; }
  .class-name { font-family: var(--display); font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 600; margin: 0; color: var(--bone); }
  .class-role { font-family: var(--mono); font-size: 0.78rem; letter-spacing: 0.04em; text-transform: uppercase; color: var(--gylden); margin: 0.5rem 0 0.9rem; }
  .class-body { color: var(--bone); margin: 0 0 1.1rem; max-width: 44rem; line-height: 1.7; }
  .sw { display: grid; gap: 1px; grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr)); background: var(--line); border: 1px solid var(--line); margin: 0; }
  .sw > div { background: var(--abyss); padding: 0.85rem 1rem; }
  .sw dt { font-family: var(--mono); font-size: 0.64rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ash); margin-bottom: 0.3rem; }
  .sw dd { margin: 0; color: var(--bone); font-size: 0.92rem; line-height: 1.5; }
</style>
