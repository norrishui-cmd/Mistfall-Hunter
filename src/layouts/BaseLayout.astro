---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  path?: string;
  image?: string;
  jsonLd?: object[];
  noindex?: boolean;
  preloadImage?: string;
}

const { title, description, lang, path = '/', image, jsonLd, noindex, preloadImage } = Astro.props;
const htmlLang = { en: 'en', zh: 'zh-Hans', de: 'de', ja: 'ja' }[lang];
const skipLabel = lang === 'zh' ? '跳到正文' : lang === 'de' ? 'Zum Inhalt' : lang === 'ja' ? '本文へ移動' : 'Skip to content';
---

<!doctype html>
<html lang={htmlLang} data-pagefind-ignore={noindex ? 'all' : undefined}>
  <head>
    <BaseHead
      title={title}
      description={description}
      lang={lang}
      path={path}
      image={image}
      jsonLd={jsonLd}
      noindex={noindex}
      preloadImage={preloadImage}
    />
  </head>
  <body>
    <a class="skip-link" href="#main">{skipLabel}</a>
    <Header lang={lang} path={path} />
    <main id="main" data-pagefind-body>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
